---
import { author } from '../data/author';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="page-wrap footer-inner">
    <div class="footer-col">
      <span class="mono-caption">Contact</span>
      <a href={`mailto:${author.email}`} class="footer-link">{author.email}</a>
    </div>
    <div class="footer-col">
      <span class="mono-caption">Public</span>
      <a href={author.links.twitter} rel="me noopener" class="footer-link"
        >@{author.handles.public}</a
      >
    </div>
    <div class="footer-col">
      <span class="mono-caption">Technical</span>
      <a href={author.links.github} rel="me noopener" class="footer-link"
        >@{author.handles.technical}</a
      >
    </div>
    <div class="footer-col footer-col-meta">
      <span class="mono-caption">{author.location} · {year}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    margin-top: var(--space-section);
    padding-block: 2.5rem 3rem;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.5rem 2rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .footer-link {
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 1px;
    font-size: 0.95rem;
    width: fit-content;
    transition:
      border-color 200ms ease,
      color 200ms ease;
  }
  .footer-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .footer-col-meta {
    color: var(--color-ink-muted);
  }

  @media (max-width: 720px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 400px) {
    .footer-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
