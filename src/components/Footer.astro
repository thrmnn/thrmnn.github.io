---
import { author } from '../data/author';
import { siteConfig, lastShipped } from '../data/site';
import ExternalLink from './primitives/ExternalLink.astro';

const year = new Date().getFullYear();

const lastShippedDate = new Date(lastShipped.date).toLocaleDateString('en-GB', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
});
---

<footer class="site-footer">
  <div class="page-wrap footer-inner">
    {/* Row 1 — contact strip */}
    <div class="footer-row footer-row--contact">
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Location</span>
        <span class="footer-value">{author.location}</span>
      </div>
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Email</span>
        <a href={`mailto:${author.email}`} class="footer-value footer-link">{author.email}</a>
      </div>
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Public</span>
        <ExternalLink href={author.links.twitter} class="footer-value footer-link" rel="me">
          @{author.handles.public}
        </ExternalLink>
      </div>
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Technical</span>
        <ExternalLink href={author.links.github} class="footer-value footer-link" rel="me">
          @{author.handles.technical}
        </ExternalLink>
      </div>
    </div>

    {/* Row 2 — credit strip */}
    <div class="footer-row footer-row--credit">
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Design &amp; Dev</span>
        <span class="footer-value">{author.name}</span>
      </div>
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Last shipped</span>
        <span class="footer-value">
          {lastShipped.title} <span class="footer-sep">·</span> {lastShippedDate}
        </span>
      </div>
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">Code</span>
        <ExternalLink href={siteConfig.repo} class="footer-value footer-link">
          Repository
        </ExternalLink>
      </div>
      <div class="footer-col">
        <span class="mono-caption--xs footer-caption">©</span>
        <span class="footer-value">{year} {author.monogram}</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-rule);
    margin-top: var(--space-section);
    padding-block: 2.25rem 2.75rem;
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .footer-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem 1.5rem;
  }
  .footer-row--credit {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }
  .footer-caption {
    /* mono-caption--xs already sets size/weight/color/tracking */
  }
  .footer-value {
    font-family: var(--font-mono);
    font-size: var(--text-mono-sm);
    line-height: 1.4;
    color: var(--color-ink);
    text-decoration: none;
    overflow-wrap: anywhere;
  }
  .footer-link {
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 1px;
    width: fit-content;
    transition:
      border-color 200ms ease,
      color 200ms ease;
  }
  .footer-link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .footer-sep {
    color: var(--color-ink-muted);
    margin-inline: 0.15rem;
  }

  @media (max-width: 720px) {
    .footer-row {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 400px) {
    .footer-row {
      grid-template-columns: 1fr;
    }
  }
</style>
