---
import type { CollectionEntry } from 'astro:content';
import Figure from './composition/Figure.astro';

interface Props {
  project: CollectionEntry<'projects'>;
  /** 'feature' = larger lead card; 'compact' = strip cell */
  variant?: 'feature' | 'compact';
}

const { project, variant = 'compact' } = Astro.props;
const { data, id } = project;
const href = `/work/${id}`;
const figureRatio = variant === 'feature' ? '16/10' : '4/3';

// Tile meta strip: STATUS · DATE · WITH — shown on hover / focus-within.
const yyyyMm = `${data.date.getFullYear()}-${String(data.date.getMonth() + 1).padStart(2, '0')}`;
const withList = data.collaborators.length > 0 ? `With ${data.collaborators.join(', ')}` : null;
const metaPieces = [data.status, yyyyMm, withList].filter(
  (p): p is string => typeof p === 'string' && p.length > 0,
);
---

<a href={href} class:list={['project-card', variant]} data-register={data.register}>
  <div class="card-media">
    <Figure
      ratio={figureRatio}
      src={data.heroImage}
      alt={data.heroAlt ?? data.title}
      pending={!data.heroImage}
    />
  </div>
  <div class="card-body">
    <h3 class="card-title">{data.title}</h3>
    {data.subtitle && <p class="card-subtitle">{data.subtitle}</p>}
    <div class="tile-meta">
      {
        metaPieces.map((piece, i) => (
          <>
            {i > 0 && (
              <span class="tile-meta-sep" aria-hidden="true">
                ·
              </span>
            )}
            <span class="tile-meta-piece">{piece}</span>
          </>
        ))
      }
    </div>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    transition: border-color 250ms ease;
  }
  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--color-rule-strong);
  }
  /* Cartesian register lifts the hover border to cool-grey (the Cartesian
     secondary accent) — gives the otherwise neutral hover a slight blue
     tint that pairs with the graphite accent. Tropical keeps the warm
     rule-strong already in place. */
  .project-card[data-register='cartesian']:hover,
  .project-card[data-register='cartesian']:focus-within {
    border-color: var(--color-cool-grey);
  }
  .project-card:hover .card-title,
  .project-card:focus-within .card-title {
    color: var(--color-accent);
  }

  /* card-media wraps Figure — let Figure own its aspect, just drop the
     bottom border so the card-body sits flush. */
  .card-media :global(.figure) {
    margin: 0;
  }
  .card-media :global(.figure-frame) {
    border-left: 0;
    border-right: 0;
    border-top: 0;
  }

  .card-body {
    padding: var(--s-4) var(--s-4) var(--s-4);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .card-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-body-lg);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    transition: color 250ms ease;
  }
  [data-register='tropical'] .card-title {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings: 'opsz' 36;
  }
  .card-subtitle {
    color: var(--color-ink-muted);
    font-size: var(--text-body-sm);
    line-height: 1.4;
  }

  /* Tile metadata — always in DOM (screen readers always announce),
     visually revealed on hover / focus-within. Reserves its height so
     cards don't shift. */
  .tile-meta {
    margin-top: var(--s-2);
    padding-top: var(--s-2);
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: var(--text-mono-xs);
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
    min-height: calc(var(--text-mono-xs) * 1.4 + var(--s-2));
    opacity: 0;
    transition: opacity 250ms ease;
  }
  .project-card:hover .tile-meta,
  .project-card:focus-within .tile-meta {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile-meta {
      opacity: 1;
    }
  }
  .tile-meta-sep {
    color: var(--color-ink-muted);
    opacity: 0.55;
  }

  /* Feature variant — title scales up; ratio handled via Figure prop. */
  .project-card.feature .card-title {
    font-size: var(--text-display-sm);
  }
</style>
