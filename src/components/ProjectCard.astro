---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** 'feature' = larger lead card; 'compact' = strip cell */
  variant?: 'feature' | 'compact';
}

const { project, variant = 'compact' } = Astro.props;
const { data, id } = project;
const href = `/work/${id}`;
---

<a href={href} class:list={['project-card', variant]} data-register={data.register}>
  <div class="card-media" aria-hidden={!data.heroImage}>
    {
      data.heroImage ? (
        <img src={data.heroImage} alt={data.heroAlt ?? ''} loading="lazy" decoding="async" />
      ) : (
        <div class="card-placeholder">
          <span class="placeholder-mark">{data.title.split(' ').slice(0, 2).join(' ')}</span>
        </div>
      )
    }
  </div>
  <div class="card-body">
    {data.status && <span class="mono-caption">{data.status}</span>}
    <h3 class="card-title">{data.title}</h3>
    {data.subtitle && <p class="card-subtitle">{data.subtitle}</p>}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    transition:
      border-color 250ms ease,
      transform 250ms ease;
  }
  .project-card:hover {
    border-color: var(--color-rule-strong);
  }
  .project-card:hover .card-title {
    color: var(--color-accent);
  }

  .card-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-paper-deep);
    border-bottom: 1px solid var(--color-rule);
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .project-card:hover .card-media img {
    transform: scale(1.02);
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    background: linear-gradient(135deg, var(--color-paper-deep) 0%, var(--color-paper) 100%);
    position: relative;
  }
  .card-placeholder::before {
    content: '';
    position: absolute;
    inset: 1.25rem;
    border: 1px solid var(--color-rule);
  }
  .placeholder-mark {
    font-family: var(--font-wordmark);
    font-variation-settings:
      'opsz' 144,
      'SOFT' 60;
    font-size: 1.5rem;
    color: var(--color-ink-soft);
    line-height: 1.1;
    max-width: 75%;
    position: relative;
    z-index: 1;
  }
  [data-register='tropical'] .card-placeholder {
    background: linear-gradient(135deg, var(--color-sand) 0%, var(--color-paper) 80%);
  }

  .card-body {
    padding: 1rem 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .card-title {
    font-family: var(--font-cartesian);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    transition: color 250ms ease;
  }
  [data-register='tropical'] .card-title {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings: 'opsz' 36;
  }
  .card-subtitle {
    color: var(--color-ink-muted);
    font-size: 0.92rem;
    line-height: 1.4;
  }

  /* Feature variant — larger, used as homepage lead */
  .project-card.feature .card-media {
    aspect-ratio: 16 / 10;
  }
  .project-card.feature .card-title {
    font-size: 1.25rem;
  }
</style>
