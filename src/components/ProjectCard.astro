---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  /** 'feature' = larger lead card; 'compact' = strip cell */
  variant?: 'feature' | 'compact';
}

const { project, variant = 'compact' } = Astro.props;
const { data, id } = project;
const href = `/work/${id}`;

// Tile meta strip: STATUS · DATE · WITH — shown on hover / focus-within.
const yyyyMm = `${data.date.getFullYear()}-${String(data.date.getMonth() + 1).padStart(2, '0')}`;
const withList = data.collaborators.length > 0 ? `With ${data.collaborators.join(', ')}` : null;
const metaPieces = [data.status, yyyyMm, withList].filter(
  (p): p is string => typeof p === 'string' && p.length > 0,
);
---

<a href={href} class:list={['project-card', variant]} data-register={data.register}>
  <div class="card-media" aria-hidden={!data.heroImage}>
    {
      data.heroImage ? (
        <img src={data.heroImage} alt={data.heroAlt ?? ''} loading="lazy" decoding="async" />
      ) : (
        <div class="card-placeholder">
          <span class="placeholder-mark">{data.title.split(' ').slice(0, 2).join(' ')}</span>
        </div>
      )
    }
  </div>
  <div class="card-body">
    <h3 class="card-title">{data.title}</h3>
    {data.subtitle && <p class="card-subtitle">{data.subtitle}</p>}
    <div class="tile-meta">
      {
        metaPieces.map((piece, i) => (
          <>
            {i > 0 && (
              <span class="tile-meta-sep" aria-hidden="true">
                ·
              </span>
            )}
            <span class="tile-meta-piece">{piece}</span>
          </>
        ))
      }
    </div>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-ink);
    border: 1px solid var(--color-rule);
    background: var(--color-paper);
    transition: border-color 250ms ease;
  }
  .project-card:hover,
  .project-card:focus-within {
    border-color: var(--color-rule-strong);
  }
  .project-card:hover .card-title,
  .project-card:focus-within .card-title {
    color: var(--color-accent);
  }

  .card-media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-paper-deep);
    border-bottom: 1px solid var(--color-rule);
  }
  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 1.25rem;
    background: linear-gradient(135deg, var(--color-paper-deep) 0%, var(--color-paper) 100%);
    position: relative;
  }
  .card-placeholder::before {
    content: '';
    position: absolute;
    inset: 1.25rem;
    border: 1px solid var(--color-rule);
  }
  .placeholder-mark {
    font-family: var(--font-wordmark);
    font-variation-settings:
      'opsz' 144,
      'SOFT' 60;
    font-size: var(--text-display-sm);
    color: var(--color-ink-soft);
    line-height: 1.1;
    max-width: 75%;
    position: relative;
    z-index: 1;
  }
  [data-register='tropical'] .card-placeholder {
    background: linear-gradient(135deg, var(--color-sand) 0%, var(--color-paper) 80%);
  }

  .card-body {
    padding: var(--s-4) var(--s-4) var(--s-4);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .card-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-body-lg);
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    transition: color 250ms ease;
  }
  [data-register='tropical'] .card-title {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings: 'opsz' 36;
  }
  .card-subtitle {
    color: var(--color-ink-muted);
    font-size: var(--text-body-sm);
    line-height: 1.4;
  }

  /* Tile metadata — always in DOM (screen readers always announce),
     visually revealed on hover / focus-within. Reserves its height so
     cards don't shift. */
  .tile-meta {
    margin-top: var(--s-2);
    padding-top: var(--s-2);
    border-top: 1px solid var(--color-rule);
    font-family: var(--font-mono);
    font-size: var(--text-mono-xs);
    line-height: 1.4;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
    min-height: calc(var(--text-mono-xs) * 1.4 + var(--s-2));
    opacity: 0;
    transition: opacity 250ms ease;
  }
  .project-card:hover .tile-meta,
  .project-card:focus-within .tile-meta {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .tile-meta {
      opacity: 1;
    }
  }
  .tile-meta-sep {
    color: var(--color-ink-muted);
    opacity: 0.55;
  }

  /* Feature variant — larger, used as homepage lead */
  .project-card.feature .card-media {
    aspect-ratio: 16 / 10;
  }
  .project-card.feature .card-title {
    font-size: var(--text-display-sm);
  }
</style>
