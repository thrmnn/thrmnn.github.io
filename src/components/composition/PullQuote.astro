---
/**
 * Pull quote — typographic event (Phase 4.7 A2).
 * Fraunces italic with opsz / SOFT / WONK axes engaged on every render.
 * Half-viewport breathing room above and below, terra accent rule on the
 * left, mono citation underneath.
 *
 * Usage:
 *   <PullQuote citation="Thesis · internal">
 *     Cartesian rigor applied to tropical complexity.
 *   </PullQuote>
 *
 * The `attribution` prop alias is kept for backward compatibility with
 * Phase 4.6 callers.
 */
interface Props {
  citation?: string;
  attribution?: string; // legacy alias for `citation`
  class?: string;
}

const { citation, attribution, class: className = '' } = Astro.props;
const credit = citation ?? attribution;
---

<figure class:list={['pull-quote', className]}>
  <blockquote class="pull-quote-body">
    <slot />
  </blockquote>
  {credit && <figcaption class="pull-quote-citation">{credit}</figcaption>}
</figure>

<style>
  .pull-quote {
    margin: var(--s-16) 0;
    padding: var(--s-4) 0 var(--s-4) var(--s-8);
    border-left: 4px solid var(--color-terra);
    max-width: 28ch;
  }
  .pull-quote-body {
    margin: 0;
    font-family: var(--font-tropical);
    font-style: italic;
    font-size: var(--text-display-md);
    line-height: 1.08;
    color: var(--color-ink);
    font-variation-settings:
      'opsz' 48,
      'SOFT' 100,
      'WONK' 1;
  }
  .pull-quote-citation {
    margin-top: var(--s-4);
    font-family: var(--font-mono);
    font-size: var(--text-mono-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-muted);
  }
</style>
