---
/**
 * Large display numeral marking a numbered section (Phase 4.7 D5).
 *
 * Display-md, light weight, terra accent — the number is a typographic
 * anchor for the section, not a label. Sticks to viewport top via
 * position: sticky so it stays beside the section body during scroll.
 *
 * Pass the number as the slot content — '01', '02', '03', '04'.
 */
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['section-number', className]}>
  <slot />
</span>

<style>
  .section-number {
    display: inline-block;
    font-family: var(--font-cartesian);
    font-size: var(--text-display-md);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1;
    color: var(--color-terra);
    font-variant-numeric: tabular-nums;
    position: sticky;
    top: var(--s-20);
  }
  :global([data-register='tropical']) .section-number {
    color: var(--color-oxblood);
  }
</style>
