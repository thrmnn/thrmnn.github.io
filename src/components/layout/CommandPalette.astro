---
import { navLinks, mobileNavLinks } from '../../data/navigation';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.draft)
  .map((p) => ({
    label: p.data.title,
    href: `/projects/${p.id}/`,
    hint: 'project',
  }));

const routes = mobileNavLinks
  .filter((l) => !l.href.startsWith('/#'))
  .map((l) => ({ label: l.label, href: l.href, hint: 'page' }));

const items = [...routes, ...projects];
---

<dialog id="command-palette" class="cmdk" aria-label="Command palette">
  <div class="cmdk-shell">
    <div class="cmdk-frame">
      <div class="cmdk-search">
        <span class="cmdk-prompt" aria-hidden="true">/</span>
        <input
          id="cmdk-input"
          type="text"
          class="cmdk-input"
          placeholder="Jump to…"
          autocomplete="off"
          spellcheck="false"
          aria-label="Search routes and projects"
          aria-controls="cmdk-list"
        />
        <kbd class="cmdk-esc" aria-hidden="true">esc</kbd>
      </div>
      <ul id="cmdk-list" class="cmdk-list" role="listbox" aria-label="Results">
        {items.map((it, i) => (
          <li
            class="cmdk-row"
            role="option"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-href={it.href}
            data-label={it.label.toLowerCase()}
          >
            <span class="cmdk-row-label">{it.label}</span>
            <span class="cmdk-row-hint" aria-hidden="true">{it.hint}</span>
          </li>
        ))}
      </ul>
      <p class="cmdk-empty" aria-hidden="true">No matches.</p>
      <div class="cmdk-foot" aria-hidden="true">
        <kbd>↑</kbd><kbd>↓</kbd><span>navigate</span>
        <kbd>↵</kbd><span>open</span>
        <kbd>esc</kbd><span>close</span>
      </div>
    </div>
  </div>
</dialog>

<style>
  .cmdk {
    position: fixed;
    inset: 0;
    padding: 0;
    border: 0;
    background: transparent;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
  }
  .cmdk::backdrop {
    background: color-mix(in srgb, var(--color-bg-primary) 70%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .cmdk[open] { display: grid; place-items: start center; padding-top: 14vh; }

  .cmdk-shell {
    width: min(620px, calc(100vw - 2rem));
  }
  .cmdk-frame {
    border: 1px solid var(--color-border-hover);
    background: color-mix(in srgb, var(--color-bg-elevated) 92%, transparent);
    border-radius: 8px;
    box-shadow:
      0 24px 60px -20px rgba(0, 0, 0, 0.6),
      0 0 0 1px color-mix(in srgb, var(--color-accent) 12%, transparent) inset;
    overflow: hidden;
  }

  .cmdk-search {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .cmdk-prompt {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 0.85rem;
  }
  .cmdk-input {
    flex: 1;
    background: transparent;
    border: 0;
    outline: 0;
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    padding: 0;
  }
  .cmdk-input::placeholder { color: var(--color-text-muted); }
  .cmdk-esc {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--color-border-hover);
    border-radius: 4px;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .cmdk-list {
    list-style: none;
    margin: 0;
    padding: 0.35rem 0;
    max-height: 50vh;
    overflow-y: auto;
  }
  .cmdk-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.55rem 1rem;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: background-color var(--dur-1) var(--ease-out), color var(--dur-1) var(--ease-out);
  }
  .cmdk-row[aria-selected="true"] {
    background: color-mix(in srgb, var(--color-accent) 14%, transparent);
    color: var(--color-text-primary);
  }
  .cmdk-row[hidden] { display: none; }
  .cmdk-row-label { font-size: 0.92rem; }
  .cmdk-row-hint {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .cmdk-empty {
    display: none;
    padding: 1rem;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    text-align: center;
    margin: 0;
  }
  .cmdk-list[data-empty="true"] + .cmdk-empty { display: block; }
  .cmdk-list[data-empty="true"] { display: none; }

  .cmdk-foot {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    border-top: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }
  .cmdk-foot kbd {
    border: 1px solid var(--color-border-hover);
    border-radius: 3px;
    padding: 0.1rem 0.32rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-text-muted);
  }
  .cmdk-foot kbd + kbd { margin-left: -0.25rem; }
  .cmdk-foot span + kbd { margin-left: 0.4rem; }

  @media (max-width: 640px) {
    .cmdk[open] { padding-top: 8vh; }
    .cmdk-foot { display: none; }
  }
</style>

<script>
  const dialog = document.getElementById('command-palette') as HTMLDialogElement | null;
  const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
  const list = document.getElementById('cmdk-list') as HTMLUListElement | null;
  if (dialog && input && list) {
    const rows = Array.from(list.querySelectorAll<HTMLLIElement>('.cmdk-row'));
    let returnFocus: Element | null = null;

    const visible = () => rows.filter((r) => !r.hidden);
    const select = (target: HTMLLIElement) => {
      for (const r of rows) r.setAttribute('aria-selected', r === target ? 'true' : 'false');
      target.scrollIntoView({ block: 'nearest' });
    };
    const filter = () => {
      const q = input.value.trim().toLowerCase();
      for (const r of rows) {
        const label = r.dataset.label || '';
        r.hidden = q.length > 0 && !label.includes(q);
      }
      const vis = visible();
      list.dataset.empty = vis.length ? 'false' : 'true';
      if (vis.length && !vis.some((r) => r.getAttribute('aria-selected') === 'true')) select(vis[0]!);
    };
    const open = () => {
      if (dialog.open) return;
      returnFocus = document.activeElement;
      input.value = '';
      filter();
      dialog.showModal();
      requestAnimationFrame(() => input.focus());
    };
    const close = () => {
      if (!dialog.open) return;
      dialog.close();
      if (returnFocus instanceof HTMLElement) returnFocus.focus();
    };
    const go = (row: HTMLLIElement) => {
      const href = row.dataset.href;
      if (!href) return;
      close();
      if (href.startsWith('http') || href.endsWith('.pdf')) window.location.href = href;
      else window.location.assign(href);
    };

    document.addEventListener('keydown', (e) => {
      const mod = e.metaKey || e.ctrlKey;
      if (mod && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        if (dialog.open) close();
        else open();
      }
    });
    dialog.addEventListener('cancel', (e) => {
      e.preventDefault();
      close();
    });
    dialog.addEventListener('click', (e) => {
      const target = e.target;
      if (target === dialog) close();
      if (target instanceof HTMLElement) {
        const row = target.closest<HTMLLIElement>('.cmdk-row');
        if (row) go(row);
      }
    });
    input.addEventListener('input', filter);
    input.addEventListener('keydown', (e) => {
      const vis = visible();
      if (!vis.length) return;
      const current = vis.find((r) => r.getAttribute('aria-selected') === 'true') || vis[0]!;
      const idx = vis.indexOf(current);
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        select(vis[(idx + 1) % vis.length]!);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        select(vis[(idx - 1 + vis.length) % vis.length]!);
      } else if (e.key === 'Enter') {
        e.preventDefault();
        go(current);
      }
    });

    document.querySelectorAll<HTMLElement>('[data-cmdk-open]').forEach((btn) => {
      btn.addEventListener('click', () => open());
    });
  }
</script>
