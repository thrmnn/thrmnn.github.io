---
import { footerLinks } from '../../data/navigation';
import { author } from '../../data/author';

const year = new Date().getFullYear();
const monogramLetters = author.monogram.split('');
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto max-w-[var(--max-w-content)] px-6 py-12">
    <div class="flex items-baseline gap-4 flex-wrap mb-6">
      <a href="/" class="footer-monogram" aria-label="Home">
        {monogramLetters.map((char) => <span>{char}</span>)}
      </a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <nav class="flex-1 flex justify-center gap-6 flex-wrap min-w-0">
        {footerLinks.map((link) => (
          <a
            href={link.href}
            class="footer-link text-sm text-text-muted hover:text-text-secondary transition-colors py-1.5 focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 focus-visible:rounded-sm"
            {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          >
            {link.label}
          </a>
        ))}
      </nav>
      <p class="footer-copy">&copy; {year} {author.name}</p>
    </div>
  </div>
</footer>

<style>
  .footer-monogram {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-monogram:hover,
  .footer-monogram:focus-visible {
    color: var(--color-text-secondary);
    outline: none;
  }
  .footer-monogram > span + span::before {
    content: '·';
    margin: 0 0.18em;
    opacity: 0.55;
  }
  .footer-sep {
    color: var(--color-border);
    font-family: var(--font-mono);
  }
  .footer-link {
    position: relative;
  }
  .footer-link::before {
    content: "";
    position: absolute;
    left: -0.7rem;
    top: 50%;
    width: 4px;
    height: 4px;
    margin-top: -2px;
    border-radius: 50%;
    border: 1px solid var(--color-accent);
    background: transparent;
    opacity: 0.25;
    transform: scale(0.6);
    transition: opacity var(--dur-1) var(--ease-out), transform var(--dur-1) var(--ease-out);
  }
  .footer-link:hover::before,
  .footer-link:focus-visible::before {
    opacity: 0.85;
    transform: scale(1);
  }
  @media (prefers-reduced-motion: reduce) {
    .footer-link::before { transition: none; }
  }
  .footer-copy {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
    margin: 0;
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .footer-sep { display: none; }
    .footer-copy { width: 100%; text-align: center; }
  }
</style>
