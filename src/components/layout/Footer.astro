---
import { footerLinks } from '../../data/navigation';
import { author } from '../../data/author';
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto max-w-[var(--max-w-content)] px-6 py-12">
    <nav class="flex justify-center gap-6 flex-wrap mb-6">
      {footerLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-text-muted hover:text-text-secondary transition-colors underline underline-offset-4 decoration-1 decoration-transparent hover:decoration-text-muted focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-4 focus-visible:rounded-sm focus-visible:decoration-transparent"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <p class="text-center text-xs text-text-muted">
      &copy; {new Date().getFullYear()} {author.name}
    </p>
  </div>
</footer>
