---
import { footerLinks } from '../../data/navigation';
---

<footer class="border-t border-border mt-24">
  <div class="mx-auto max-w-[var(--max-w-content)] px-6 py-12">
    <nav class="flex justify-center gap-6 flex-wrap mb-6">
      {footerLinks.map((link) => (
        <a
          href={link.href}
          id={link.id}
          class="text-sm text-text-muted hover:text-text-secondary transition-colors"
          {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <p class="text-center text-xs text-text-muted">
      &copy; {new Date().getFullYear()} Théo Hermann
    </p>
  </div>
</footer>

<script is:inline>
  (function() {
    var m = 'bWFpbHRvOnRoZXJtYW5uQG1pdC5lZHU=';
    function p() {
      var el = document.getElementById('footer-email');
      if (el) el.setAttribute('href', atob(m));
    }
    document.addEventListener('DOMContentLoaded', p);
    document.addEventListener('astro:page-load', p);
  })();
</script>
