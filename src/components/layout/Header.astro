---
import { navLinks, mobileNavLinks } from '../../data/navigation';
import ThemeToggle from '../ui/ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === currentPath ||
  (href !== '/' && !href.startsWith('/#') && currentPath.startsWith(href));
---

<header class="site-header" data-header data-open="false">
  <div class="header-pill">
    <div class="header-inner">
      <!-- Left: monogram (also the Home affordance) -->
      <a href="/" aria-label="Théo Alessandro Hermann — Home" class="monogram-link">
        <span class="monogram" aria-hidden="true">
          <span class="mono-ch" style="--i:0">T</span>
          <span class="mono-ch" style="--i:1">·</span>
          <span class="mono-ch" style="--i:2">A</span>
          <span class="mono-ch" style="--i:3">·</span>
          <span class="mono-ch" style="--i:4">H</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="header-nav" aria-label="Primary">
        <ul>
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="nav-link"
                {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Controls -->
      <div class="header-controls">
        <ThemeToggle />
        <button
          type="button"
          id="nav-toggle-btn"
          class="nav-burger"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Toggle navigation"
        >
          <svg class="burger-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg class="burger-close" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu">
    <ul>
      {mobileNavLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link"
            {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  /* ============================ Floating instrument pill ============================ */
  .site-header {
    position: fixed;
    top: 0.85rem;
    left: 0;
    right: 0;
    z-index: 50;
    padding: 0 1rem;
    pointer-events: none;          /* clicks pass through gutters, only pill catches */
    transition: top var(--dur-2) var(--ease-out);
  }
  .site-header.condensed { top: 0.55rem; }

  .header-pill {
    position: relative;
    pointer-events: auto;
    max-width: 880px;
    margin: 0 auto;
    border: 1px solid color-mix(in srgb, var(--color-border) 80%, transparent);
    border-radius: 999px;
    background-color: color-mix(in srgb, var(--color-bg-primary) 60%, transparent);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow:
      0 14px 32px -16px rgba(0, 0, 0, 0.18),
      0 1px 0 0 rgba(255, 255, 255, 0.55) inset,
      0 0 0 1px color-mix(in srgb, var(--color-accent) 9%, transparent) inset;
    transition:
      background-color var(--dur-2) var(--ease-out),
      border-color var(--dur-2) var(--ease-out),
      box-shadow var(--dur-2) var(--ease-out);
  }
  /* Faint inner top highlight for "glass" depth. */
  .header-pill::before {
    content: "";
    position: absolute;
    inset: 1px 1px auto 1px;
    height: 50%;
    border-radius: inherit;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0.35) 0%,
      transparent 100%
    );
    pointer-events: none;
  }
  .site-header.condensed .header-pill {
    background-color: color-mix(in srgb, var(--color-bg-primary) 82%, transparent);
    border-color: var(--color-border-hover);
    box-shadow:
      0 8px 22px -14px rgba(0, 0, 0, 0.22),
      0 1px 0 0 rgba(255, 255, 255, 0.5) inset,
      0 0 0 1px color-mix(in srgb, var(--color-accent) 7%, transparent) inset;
  }
  /* Dark-mode tuning — deeper shadow + cooler highlight. */
  [data-theme="dark"] .header-pill {
    background-color: color-mix(in srgb, var(--color-bg-primary) 42%, transparent);
    border-color: color-mix(in srgb, var(--color-border) 65%, transparent);
    box-shadow:
      0 18px 46px -20px rgba(0, 0, 0, 0.7),
      0 1px 0 0 color-mix(in srgb, #ffffff 6%, transparent) inset,
      0 0 0 1px color-mix(in srgb, var(--color-accent) 7%, transparent) inset;
  }
  [data-theme="dark"] .header-pill::before {
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, #ffffff 4%, transparent) 0%,
      transparent 100%
    );
  }
  [data-theme="dark"] .site-header.condensed .header-pill {
    background-color: color-mix(in srgb, var(--color-bg-primary) 75%, transparent);
    border-color: var(--color-border);
    box-shadow:
      0 8px 22px -12px rgba(0, 0, 0, 0.6),
      0 1px 0 0 color-mix(in srgb, #ffffff 4%, transparent) inset,
      0 0 0 1px color-mix(in srgb, var(--color-accent) 5%, transparent) inset;
  }
  @media (prefers-color-scheme: dark) {
    :root:not([data-theme]) .header-pill {
      background-color: color-mix(in srgb, var(--color-bg-primary) 42%, transparent);
      border-color: color-mix(in srgb, var(--color-border) 65%, transparent);
      box-shadow:
        0 18px 46px -20px rgba(0, 0, 0, 0.7),
        0 1px 0 0 color-mix(in srgb, #ffffff 6%, transparent) inset,
        0 0 0 1px color-mix(in srgb, var(--color-accent) 7%, transparent) inset;
    }
    :root:not([data-theme]) .header-pill::before {
      background: linear-gradient(
        to bottom,
        color-mix(in srgb, #ffffff 4%, transparent) 0%,
        transparent 100%
      );
    }
    :root:not([data-theme]) .site-header.condensed .header-pill {
      background-color: color-mix(in srgb, var(--color-bg-primary) 75%, transparent);
    }
  }
  /* Fallback for browsers without backdrop-filter — bump the bg up so the
     content stays legible without the blur trick. */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .header-pill { background-color: var(--color-bg-primary); }
  }

  .header-inner {
    padding: 0 1rem 0 1.25rem;
    height: 3.1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  /* Nav — monospace instrument list */
  .header-nav ul {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }
  .nav-link {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--color-text-muted);
    transition: color var(--dur-1) var(--ease-out);
    padding: 0.3rem 0;
  }
  .nav-link::before {
    content: "";
    position: absolute;
    left: -0.7rem;
    top: 50%;
    width: 4px;
    height: 4px;
    margin-top: -2px;
    background: var(--color-accent);
    opacity: 0;
    transform: scale(0.4);
    transition: opacity var(--dur-1) var(--ease-out), transform var(--dur-1) var(--ease-out);
  }
  .nav-link:hover {
    color: var(--color-text-secondary);
  }
  .nav-link:hover::before {
    background: transparent;
    box-shadow: inset 0 0 0 1px var(--color-accent);
    opacity: 0.85;
    transform: scale(0.9);
  }
  .nav-link[aria-current='page'] {
    color: var(--color-text-primary);
  }
  .nav-link[aria-current='page']::before {
    opacity: 1;
    transform: scale(1);
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
    color: var(--color-text-primary);
  }
  .nav-link:focus-visible::before {
    opacity: 1;
    transform: scale(1);
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Burger */
  .nav-burger {
    display: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0.65rem;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    margin-right: -0.35rem;
    background: transparent;
    border: 0;
    appearance: none;
    -webkit-appearance: none;
  }
  .nav-burger svg { width: 1.35rem; height: 1.35rem; display: block; transition: transform var(--dur-1) var(--ease-out); }
  .nav-burger:hover { color: var(--color-text-primary); }
  .nav-burger:active {
    background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);
    border-radius: 6px;
  }
  .nav-burger:active svg { transform: scale(0.92); }
  .nav-burger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-burger svg, .nav-burger:active svg { transition: none; transform: none; }
  }
  .burger-close { display: none; }
  .site-header[data-open="true"] .nav-burger .burger-open { display: none; }
  .site-header[data-open="true"] .nav-burger .burger-close { display: block; }

  /* Mobile menu */
  .mobile-menu {
    pointer-events: auto;
    display: none;
    max-width: 880px;
    margin: 0.55rem auto 0;
    padding: 0;
    border: 1px solid var(--color-border-hover);
    border-radius: 14px;
    background-color: color-mix(in srgb, var(--color-bg-primary) 92%, transparent);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    box-shadow: 0 14px 40px -16px rgba(0, 0, 0, 0.55);
  }
  .site-header[data-open="true"] .mobile-menu { display: block; }
  .mobile-menu ul {
    padding: 0.85rem 1.1rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .header-nav {
      display: none;
    }
    .nav-burger { display: flex; }
    .mobile-menu .nav-link {
      min-height: 44px;
      display: flex;
      align-items: center;
      font-size: 0.9rem;
      padding-left: 0.95rem;
    }
    .mobile-menu .nav-link[aria-current='page'] {
      color: var(--color-text-primary);
    }
    .mobile-menu .nav-link[aria-current='page']::before {
      left: 0;
      opacity: 1;
      transform: scale(1.4);
    }
  }

  /* --- T·A·H monogram --- */
  .monogram-link { color: var(--color-text-primary); }
  .monogram {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.35rem;
    line-height: 1;
    letter-spacing: normal;
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .mono-ch { display: inline-block; }

  .monogram::after {
    content: "";
    position: absolute;
    top: -3px;
    bottom: -3px;
    left: 0;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mono-ch {
      opacity: 0;
      animation: mono-in 0.5s ease forwards;
      animation-delay: calc(var(--i) * 0.07s);
    }
  }
  @media (prefers-reduced-motion: no-preference) and (pointer: fine) {
    .monogram-link:hover .monogram::after {
      animation: mono-scan 0.55s ease;
    }
  }
  @keyframes mono-in {
    from { opacity: 0; transform: translateY(0.22em); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes mono-scan {
    0%   { left: -2px; opacity: 0; }
    25%  { opacity: 1; }
    75%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
</style>

<script>
  // Instrument-console header: scroll-progress scan line, condensed state,
  // and a live readout that names the section currently in view.
  (() => {
    const header = document.querySelector('[data-header]') as HTMLElement | null;
    if (!header) return;

    let ticking = false;
    let wasCondensed = false;
    function update() {
      ticking = false;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const p = max > 0 ? Math.min(1, window.scrollY / max) : 0;
      document.documentElement.style.setProperty('--progress', String(p));
      const condensed = window.scrollY > 32;
      if (condensed !== wasCondensed) {
        header!.classList.toggle('condensed', condensed);
        wasCondensed = condensed;
      }
    }
    window.addEventListener(
      'scroll',
      () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } },
      { passive: true },
    );
    update();

    const burger = document.getElementById('nav-toggle-btn') as HTMLButtonElement | null;
    const mobileMenu = document.getElementById('mobile-menu');
    if (mobileMenu) mobileMenu.setAttribute('inert', '');
    if (burger && mobileMenu) {
      const backgroundEls = (): HTMLElement[] =>
        Array.from(document.querySelectorAll('main, footer')) as HTMLElement[];
      const setOpen = (open: boolean) => {
        header!.setAttribute('data-open', String(open));
        burger.setAttribute('aria-expanded', String(open));
        mobileMenu.toggleAttribute('inert', !open);
        for (const el of backgroundEls()) el.toggleAttribute('inert', open);
        if (open) {
          requestAnimationFrame(() => (mobileMenu.querySelector('a') as HTMLElement | null)?.focus());
        }
      };
      const isOpen = () => header!.getAttribute('data-open') === 'true';
      burger.addEventListener('click', () => setOpen(!isOpen()));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen()) {
          setOpen(false);
          burger.focus();
        }
      });
      document.addEventListener('click', (e) => {
        if (!isOpen()) return;
        if (!header!.contains(e.target as Node)) setOpen(false);
      });
      mobileMenu.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement).closest('a');
        if (a && mobileMenu.contains(a) && isOpen()) setOpen(false);
      });
    }
  })();
</script>
