---
import { navLinks } from '../../data/navigation';
import ThemeToggle from '../ui/ThemeToggle.astro';

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-bg-primary/80 backdrop-blur-md border-b border-border">
  <!-- Checkbox peer lives here, as a direct child of header, before nav and mobile menu -->
  <input type="checkbox" id="nav-toggle" class="hidden peer" aria-hidden="true" tabindex="-1" />

  <nav class="mx-auto max-w-[var(--max-w-content)] px-6 h-16 flex items-center justify-between">
    <a
      href="/"
      aria-label="Théo Alessandro Hermann — Home"
      class="monogram-link flex items-center"
    >
      <!-- T·A·H monogram — Space Grotesk, literal middle-dot characters -->
      <span class="monogram" aria-hidden="true">
        <span class="mono-ch" style="--i:0">T</span>
        <span class="mono-ch" style="--i:1">·</span>
        <span class="mono-ch" style="--i:2">A</span>
        <span class="mono-ch" style="--i:3">·</span>
        <span class="mono-ch" style="--i:4">H</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && !link.href.startsWith('/#') && currentPath.startsWith(link.href))
                ? 'text-text-primary'
                : 'text-text-muted hover:text-text-secondary',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side controls: theme toggle + mobile hamburger -->
    <div class="flex items-center gap-2">
      <ThemeToggle />

      <!-- Mobile hamburger label (for= works regardless of nesting) -->
      <label
        for="nav-toggle"
        aria-label="Toggle navigation menu"
        aria-controls="mobile-menu"
        class="md:hidden cursor-pointer text-text-secondary p-2"
      >
        <!-- Hamburger icon (visible when menu closed) -->
        <svg class="w-5 h-5 block peer-checked-hide" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- X close icon (visible when menu open) -->
        <svg class="w-5 h-5 hidden peer-checked-show" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </label>
    </div>
  </nav>

  <!-- Mobile menu (subsequent sibling of the checkbox peer, so peer-checked: works) -->
  <div id="mobile-menu" class="hidden peer-checked:block md:hidden border-t border-border bg-bg-primary/95 backdrop-blur-md">
    <ul class="px-6 py-4 space-y-3">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block text-sm font-medium py-1',
              currentPath === link.href ? 'text-text-primary' : 'text-text-muted',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  /* Toggle hamburger / X icon based on checkbox state. */
  #nav-toggle:checked ~ nav .peer-checked-hide { display: none; }
  #nav-toggle:checked ~ nav .peer-checked-show { display: block; }

  /* --- T·A·H monogram --- */
  .monogram-link { color: var(--color-text-primary); }

  .monogram {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.35rem;
    line-height: 1;
    letter-spacing: normal;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .mono-ch { display: inline-block; }

  /* Scan-sweep line, runs on hover */
  .monogram::after {
    content: "";
    position: absolute;
    top: -3px;
    bottom: -3px;
    left: 0;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mono-ch {
      opacity: 0;
      animation: mono-in 0.5s ease forwards;
      animation-delay: calc(var(--i) * 0.07s);
    }
  }

  @media (prefers-reduced-motion: no-preference) and (pointer: fine) {
    .monogram-link:hover .monogram::after {
      animation: mono-scan 0.55s ease;
    }
  }

  @keyframes mono-in {
    from { opacity: 0; transform: translateY(0.22em); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes mono-scan {
    0%   { left: -2px; opacity: 0; }
    25%  { opacity: 1; }
    75%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
</style>
