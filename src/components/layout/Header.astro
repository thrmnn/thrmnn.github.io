---
import { navLinks, mobileNavLinks } from '../../data/navigation';
import ThemeToggle from '../ui/ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === currentPath ||
  (href !== '/' && !href.startsWith('/#') && currentPath.startsWith(href));

const routeReadouts: Record<string, string> = {
  '/': 'home',
  '/projects': 'work',
  '/consulting': 'consulting',
  '/now': 'signal',
  '/cv': 'dossier',
};
const seg = '/' + (currentPath.split('/').filter(Boolean)[0] ?? '');
const initialReadout = routeReadouts[currentPath] ?? routeReadouts[seg] ?? (seg.replace('/', '') || 'home');
---

<header class="site-header" data-header data-open="false">
  <div class="header-inner">
    <!-- Left: monogram + live scan readout -->
    <div class="header-left">
      <a href="/" aria-label="Théo Alessandro Hermann — Home" class="monogram-link">
        <span class="monogram" aria-hidden="true">
          <span class="mono-ch" style="--i:0">T</span>
          <span class="mono-ch" style="--i:1">·</span>
          <span class="mono-ch" style="--i:2">A</span>
          <span class="mono-ch" style="--i:3">·</span>
          <span class="mono-ch" style="--i:4">H</span>
        </span>
      </a>
      <span class="header-rule" aria-hidden="true"></span>
      <span class="header-readout">
        <span class="readout-tick" aria-hidden="true">&#9656;</span>
        <span data-readout aria-hidden="true">{initialReadout}</span>
      </span>
    </div>

    <!-- Desktop nav -->
    <nav class="header-nav" aria-label="Primary">
      <ul>
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link"
              {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Controls -->
    <div class="header-controls">
      <button
        type="button"
        class="cmdk-trigger"
        data-cmdk-open
        aria-label="Open command palette (⌘K)"
        title="Search · ⌘K"
      >
        <span class="cmdk-trigger-label">search</span>
        <kbd class="cmdk-trigger-kbd" aria-hidden="true"><span class="cmdk-mod">⌘</span>K</kbd>
      </button>
      <ThemeToggle />
      <button
        type="button"
        id="nav-toggle-btn"
        class="nav-burger"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <svg class="burger-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="burger-close" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Scan-progress line — fills with scroll position -->
  <div class="header-progress" data-progress aria-hidden="true"></div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="mobile-menu">
    <ul>
      {mobileNavLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link"
            {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  /* ============================ Instrument-console header ============================ */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background-color: color-mix(in srgb, var(--color-bg-primary) 76%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--dur-2) var(--ease-out), border-color var(--dur-2) var(--ease-out);
  }
  .site-header.condensed {
    background-color: color-mix(in srgb, var(--color-bg-primary) 94%, transparent);
    border-bottom-color: var(--color-border-hover);
  }

  .header-inner {
    max-width: var(--max-w-content);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }

  /* Divider between monogram and readout */
  .header-rule {
    width: 1px;
    height: 1.15rem;
    background: var(--color-border-hover);
  }

  /* Live scan readout */
  .header-readout {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: lowercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .readout-tick {
    color: var(--color-accent);
    font-size: 0.6rem;
    animation: readout-pulse 2.6s ease-in-out infinite;
  }
  [data-readout] {
    display: inline-block;
    color: var(--color-text-secondary);
    transition: color var(--dur-1) var(--ease-out), opacity 90ms var(--ease-out), transform 90ms var(--ease-out);
  }
  .header-readout [data-readout].swapping {
    opacity: 0.25;
    transform: translateX(2px);
    transition: opacity 90ms var(--ease-out), transform 90ms var(--ease-out);
  }
  @keyframes readout-pulse {
    0%, 100% { opacity: 0.4; }
    50%      { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .readout-tick { animation: none; opacity: 1; }
  }

  /* Nav — monospace instrument list */
  .header-nav ul {
    display: flex;
    align-items: center;
    gap: 1.6rem;
  }
  .nav-link {
    position: relative;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    color: var(--color-text-muted);
    transition: color var(--dur-1) var(--ease-out);
    padding: 0.3rem 0;
  }
  .nav-link::before {
    content: "";
    position: absolute;
    left: -0.7rem;
    top: 50%;
    width: 4px;
    height: 4px;
    margin-top: -2px;
    background: var(--color-accent);
    opacity: 0;
    transform: scale(0.4);
    transition: opacity var(--dur-1) var(--ease-out), transform var(--dur-1) var(--ease-out);
  }
  .nav-link:hover {
    color: var(--color-text-secondary);
  }
  .nav-link:hover::before {
    background: transparent;
    box-shadow: inset 0 0 0 1px var(--color-accent);
    opacity: 0.85;
    transform: scale(0.9);
  }
  .nav-link[aria-current='page'] {
    color: var(--color-text-primary);
  }
  .nav-link[aria-current='page']::before {
    opacity: 1;
    transform: scale(1);
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
    border-radius: 2px;
    color: var(--color-text-primary);
  }
  .nav-link:focus-visible::before {
    opacity: 1;
    transform: scale(1);
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Scan-progress line */
  .header-progress {
    position: absolute;
    left: 0;
    bottom: -1px;
    height: 1px;
    width: 100%;
    transform: scaleX(var(--progress, 0));
    transform-origin: left center;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-accent) 0%, transparent) 0%,
      color-mix(in srgb, var(--color-accent) 70%, transparent) 40%,
      var(--color-accent) 100%
    );
    box-shadow: 0 0 6px color-mix(in srgb, var(--color-accent) 45%, transparent),
      0 0 12px color-mix(in srgb, var(--color-accent) 25%, transparent);
    contain: strict;
    will-change: transform;
  }
  /* Idle pulse — only when not condensed (i.e. near top of page) so the
     hairline reads as 'live instrument' on first paint, then settles into
     pure scroll feedback as the user reads down. */
  @media (prefers-reduced-motion: no-preference) {
    .site-header:not(.condensed) .header-progress {
      animation: scan-idle 4.4s ease-in-out infinite;
    }
  }
  @keyframes scan-idle {
    0%, 100% { opacity: 0.55; }
    50%      { opacity: 1; }
  }

  /* ⌘K command palette trigger */
  .cmdk-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.32rem 0.55rem 0.32rem 0.65rem;
    background: color-mix(in srgb, var(--color-bg-elevated) 75%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: border-color var(--dur-1) var(--ease-out),
      color var(--dur-1) var(--ease-out),
      background-color var(--dur-1) var(--ease-out);
    appearance: none;
    -webkit-appearance: none;
  }
  .cmdk-trigger:hover,
  .cmdk-trigger:focus-visible {
    color: var(--color-text-secondary);
    border-color: var(--color-border-hover);
    background: var(--color-bg-elevated);
  }
  .cmdk-trigger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
  .cmdk-trigger-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.16em;
    text-transform: lowercase;
  }
  .cmdk-trigger-kbd {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    padding: 0.08rem 0.32rem;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-bg-primary) 50%, transparent);
  }
  .cmdk-mod { margin-right: 0.05em; }
  @media (max-width: 640px) {
    .cmdk-trigger-label { display: none; }
    .cmdk-trigger { padding: 0.32rem 0.5rem; }
  }

  /* Burger */
  .nav-burger {
    display: none;
    cursor: pointer;
    color: var(--color-text-secondary);
    padding: 0.65rem;
    min-width: 44px;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    margin-right: -0.35rem;
    background: transparent;
    border: 0;
    appearance: none;
    -webkit-appearance: none;
  }
  .nav-burger svg { width: 1.35rem; height: 1.35rem; display: block; transition: transform var(--dur-1) var(--ease-out); }
  .nav-burger:hover { color: var(--color-text-primary); }
  .nav-burger:active {
    background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);
    border-radius: 6px;
  }
  .nav-burger:active svg { transform: scale(0.92); }
  .nav-burger:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-burger svg, .nav-burger:active svg { transition: none; transform: none; }
  }
  .burger-close { display: none; }
  .site-header[data-open="true"] .nav-burger .burger-open { display: none; }
  .site-header[data-open="true"] .nav-burger .burger-close { display: block; }

  /* Mobile menu */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-border);
    background-color: color-mix(in srgb, var(--color-bg-primary) 96%, transparent);
    backdrop-filter: blur(12px);
  }
  .site-header[data-open="true"] .mobile-menu { display: block; }
  .mobile-menu ul {
    padding: 1rem 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  /* Responsive */
  @media (max-width: 767px) {
    .header-nav {
      display: none;
    }
    .nav-burger { display: flex; }
    .header-readout { font-size: 0.66rem; gap: 0.3rem; }
    .header-rule { display: inline-block; height: 0.9rem; }
    .mobile-menu .nav-link {
      min-height: 44px;
      display: flex;
      align-items: center;
      font-size: 0.9rem;
      padding-left: 0.95rem;
    }
    .mobile-menu .nav-link[aria-current='page'] {
      color: var(--color-text-primary);
    }
    .mobile-menu .nav-link[aria-current='page']::before {
      left: 0;
      opacity: 1;
      transform: scale(1.4);
    }
  }

  /* --- T·A·H monogram --- */
  .monogram-link { color: var(--color-text-primary); }
  .monogram {
    position: relative;
    display: inline-block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 1.35rem;
    line-height: 1;
    letter-spacing: normal;
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .mono-ch { display: inline-block; }

  .monogram::after {
    content: "";
    position: absolute;
    top: -3px;
    bottom: -3px;
    left: 0;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(to bottom, transparent, var(--color-accent), transparent);
    opacity: 0;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .mono-ch {
      opacity: 0;
      animation: mono-in 0.5s ease forwards;
      animation-delay: calc(var(--i) * 0.07s);
    }
  }
  @media (prefers-reduced-motion: no-preference) and (pointer: fine) {
    .monogram-link:hover .monogram::after {
      animation: mono-scan 0.55s ease;
    }
  }
  @keyframes mono-in {
    from { opacity: 0; transform: translateY(0.22em); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes mono-scan {
    0%   { left: -2px; opacity: 0; }
    25%  { opacity: 1; }
    75%  { opacity: 1; }
    100% { left: 100%; opacity: 0; }
  }
</style>

<script>
  // Instrument-console header: scroll-progress scan line, condensed state,
  // and a live readout that names the section currently in view.
  (() => {
    const header = document.querySelector('[data-header]') as HTMLElement | null;
    if (!header) return;

    let ticking = false;
    let wasCondensed = false;
    function update() {
      ticking = false;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const p = max > 0 ? Math.min(1, window.scrollY / max) : 0;
      document.documentElement.style.setProperty('--progress', String(p));
      const condensed = window.scrollY > 32;
      if (condensed !== wasCondensed) {
        header!.classList.toggle('condensed', condensed);
        wasCondensed = condensed;
      }
    }
    window.addEventListener(
      'scroll',
      () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } },
      { passive: true },
    );
    update();

    const routeReadouts: Record<string, string> = {
      projects: 'work', consulting: 'consulting', now: 'signal', cv: 'dossier',
    };

    // Live section readout
    const readout = header.querySelector('[data-readout]') as HTMLElement | null;
    if (readout) {
      const labels: Record<string, string> = {
        home: 'home', about: 'bio', projects: 'work', news: 'signal', contact: 'channel',
      };
      const sections = document.querySelectorAll('main section[id]');
      if (window.location.pathname === '/' && sections.length) {
        let pendingId: string | null = null;
        let pendingTimer: number | null = null;
        let lastSwapAt = 0;
        let scanLock = false;
        let sectionLabel = 'home';
        const applySwap = (next: string) => {
          if (readout.textContent === next) return;
          const now = performance.now();
          if (now - lastSwapAt < 120) return;
          lastSwapAt = now;
          const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (reduced) {
            readout.textContent = next;
            return;
          }
          readout.classList.add('swapping');
          requestAnimationFrame(() => requestAnimationFrame(() => {
            readout.textContent = next;
            readout.classList.remove('swapping');
          }));
        };
        const atHeroTop = () => window.scrollY < 24;
        window.addEventListener('hero:model', (e) => {
          if (!atHeroTop()) return;
          scanLock = true;
          if (pendingTimer !== null) { window.clearTimeout(pendingTimer); pendingTimer = null; }
          applySwap(`scan · ${(e as CustomEvent).detail}`);
        });
        window.addEventListener('hero:settled', () => {
          scanLock = false;
          applySwap(sectionLabel);
        });
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                const id = (e.target as HTMLElement).id;
                const next = labels[id] || id;
                sectionLabel = next;
                if (scanLock) {
                  scanLock = false;
                  if (pendingTimer !== null) { window.clearTimeout(pendingTimer); pendingTimer = null; }
                  pendingId = next;
                  applySwap(next);
                  continue;
                }
                if (pendingId === next) continue;
                pendingId = next;
                if (pendingTimer !== null) window.clearTimeout(pendingTimer);
                pendingTimer = window.setTimeout(() => { applySwap(next); }, 400);
              }
            }
          },
          { rootMargin: '-48% 0px -48% 0px' },
        );
        sections.forEach((s) => io.observe(s));
      } else {
        const seg = window.location.pathname.split('/').filter(Boolean)[0];
        readout.textContent = seg ? (routeReadouts[seg] ?? seg) : 'home';
      }
    }

    const burger = document.getElementById('nav-toggle-btn') as HTMLButtonElement | null;
    const mobileMenu = document.getElementById('mobile-menu');
    if (mobileMenu) mobileMenu.setAttribute('inert', '');
    if (burger && mobileMenu) {
      const backgroundEls = (): HTMLElement[] =>
        Array.from(document.querySelectorAll('main, footer')) as HTMLElement[];
      const setOpen = (open: boolean) => {
        header!.setAttribute('data-open', String(open));
        burger.setAttribute('aria-expanded', String(open));
        mobileMenu.toggleAttribute('inert', !open);
        for (const el of backgroundEls()) el.toggleAttribute('inert', open);
        if (open) {
          requestAnimationFrame(() => (mobileMenu.querySelector('a') as HTMLElement | null)?.focus());
        }
      };
      const isOpen = () => header!.getAttribute('data-open') === 'true';
      burger.addEventListener('click', () => setOpen(!isOpen()));
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen()) {
          setOpen(false);
          burger.focus();
        }
      });
      document.addEventListener('click', (e) => {
        if (!isOpen()) return;
        if (!header!.contains(e.target as Node)) setOpen(false);
      });
      mobileMenu.addEventListener('click', (e) => {
        const a = (e.target as HTMLElement).closest('a');
        if (a && mobileMenu.contains(a) && isOpen()) setOpen(false);
      });
    }
  })();
</script>
