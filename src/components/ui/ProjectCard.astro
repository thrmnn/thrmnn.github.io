---
interface Props {
  title: string;
  label?: string;
  metric?: string;
  tags?: string[];
  detail?: string;
  href: string;
  gradient?: string;
  image?: string;
  number?: number;
  index?: number;
}

const { title, label, metric, tags = [], detail, href, gradient, image, number, index = 0 } = Astro.props;

const bgStyle = image
  ? `background-image: url('${image}'); background-size: cover; background-position: center;`
  : `background: ${gradient || 'linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)'};`;

const displayNumber = number ? String(number).padStart(2, '0') : undefined;
const isExternal = /^https?:\/\//.test(href);
const visibleTags = tags.slice(0, 3);
---

<a
  href={href}
  target={isExternal ? '_blank' : undefined}
  rel={isExternal ? 'noopener' : undefined}
  class="block group"
  data-reveal
  style={`--reveal-d: ${index}`}
>
  <div class="project-card relative rounded-2xl overflow-hidden min-h-[340px] border border-border cursor-pointer transition-all duration-500 hover:border-border-hover">

    {/* Background layer: image or gradient */}
    <div class="card-bg absolute inset-0 transition-transform duration-700 ease-out group-hover:scale-110" style={bgStyle}></div>

    {/* Subtle noise texture overlay (gradient placeholders only) */}
    {!image && (
      <div class="absolute inset-0 noise-overlay opacity-[0.04]"></div>
    )}

    {/* Decorative number — placeholder cards only */}
    {displayNumber && !image && (
      <div class="absolute top-4 left-5 font-mono text-[3.5rem] font-black leading-none text-white/[0.08] group-hover:text-white/[0.14] transition-all duration-700 select-none tracking-tighter">
        {displayNumber}
      </div>
    )}

    {/* Darkening gradient overlay for text readability */}
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/5"></div>

    {/* Sensor layer — cursor-tracked point reveal + detection glow */}
    <div class="card-sensor absolute inset-0" aria-hidden="true"></div>

    {/* Content */}
    <div class="absolute inset-0 flex flex-col justify-end p-6 text-white">
      {label && (
        <p class="text-[0.7rem] uppercase tracking-wider text-white/60 mb-1 font-medium">
          {label}
        </p>
      )}
      <p class="text-lg font-bold leading-snug text-white" style="font-family: var(--font-display);">
        {title}
      </p>
      {metric && (
        <span class="card-metric inline-flex items-center text-[0.7rem] font-semibold text-white/90 mt-2.5 px-2.5 py-1 border border-white/20 rounded-md w-fit backdrop-blur-sm bg-white/[0.05]">
          {metric}
        </span>
      )}
      {visibleTags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-2.5">
          {visibleTags.map((tag) => (
            <span class="text-[0.65rem] text-white/55 bg-white/[0.04] px-1.5 py-0.5 rounded">
              {tag}
            </span>
          ))}
        </div>
      )}
      {detail && (
        <p class="card-detail text-sm leading-relaxed text-white/80 line-clamp-3">
          {detail}
        </p>
      )}
    </div>
  </div>
</a>

<style>
  /* Card hover glow + lift */
  .project-card {
    --mx: 50%;
    --my: 50%;
    box-shadow: 0 0 0 0 transparent, 0 2px 8px rgba(0, 0, 0, 0.3);
    transition:
      box-shadow 0.5s ease,
      border-color 0.5s ease,
      transform 0.5s ease;
  }

  .group:hover .project-card {
    box-shadow:
      0 0 20px rgba(59, 130, 246, 0.15),
      0 0 40px rgba(59, 130, 246, 0.05),
      0 8px 30px rgba(0, 0, 0, 0.25);
    transform: translateY(-4px);
  }

  /* Brighten gradient on hover */
  .group:hover .card-bg {
    filter: brightness(1.2) saturate(1.15);
  }

  /* Noise texture using SVG data URI */
  .noise-overlay {
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
    background-size: 128px 128px;
  }

  /* Sensor layer: a detection glow + a point field revealed around the cursor */
  .card-sensor {
    opacity: 0;
    transition: opacity 0.35s ease;
    background: radial-gradient(
      circle 150px at var(--mx) var(--my),
      rgba(96, 165, 250, 0.16),
      transparent 72%
    );
  }

  .card-sensor::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 255, 255, 0.55) 1px, transparent 1px);
    background-size: 15px 15px;
    -webkit-mask-image: radial-gradient(circle 100px at var(--mx) var(--my), #000 8%, transparent 74%);
    mask-image: radial-gradient(circle 100px at var(--mx) var(--my), #000 8%, transparent 74%);
  }

  .card-sensor::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid transparent;
    background: radial-gradient(
      circle 130px at var(--mx) var(--my),
      rgba(96, 165, 250, 0.5),
      transparent 70%
    ) border-box;
    -webkit-mask:
      linear-gradient(#000 0 0) padding-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
  }

  .group:hover .card-sensor {
    opacity: 1;
  }

  /* Expand detail on hover */
  .card-detail {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, margin 0.3s ease, opacity 0.3s ease;
    margin: 0;
  }

  .group:hover .card-detail,
  .project-card:focus-within .card-detail {
    max-height: 5rem;
    opacity: 1;
    margin-top: 0.625rem;
  }

  @media (max-width: 768px) {
    .card-detail {
      max-height: 5rem;
      opacity: 1;
      margin-top: 0.625rem;
    }

    .group:hover .project-card {
      transform: translateY(-2px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .card-bg,
    .card-detail,
    .card-sensor {
      transition: none;
    }
    .group:hover .project-card {
      transform: none;
    }
    .group:hover .card-bg {
      transform: none;
    }
  }
</style>

<script>
  // Project cards behave like the hero sensor: the cursor position drives a
  // CSS-variable spotlight that reveals a point field + detection glow.
  // Fine-pointer only; honours reduced-motion (the layer just stays hidden).
  (() => {
    if (
      !window.matchMedia('(pointer: fine)').matches ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) return;

    for (const card of document.querySelectorAll<HTMLElement>('.project-card')) {
      let frame = 0;
      card.addEventListener('pointermove', (e) => {
        if (frame) return;
        frame = requestAnimationFrame(() => {
          frame = 0;
          const r = card.getBoundingClientRect();
          card.style.setProperty('--mx', `${e.clientX - r.left}px`);
          card.style.setProperty('--my', `${e.clientY - r.top}px`);
        });
      }, { passive: true });
    }
  })();
</script>
