---
/**
 * ProjectCarousel — full-bleed "specimen rail".
 * Two modes, set via data-mode:
 *   shelf (server default) — native horizontal scroller. This single state is
 *     the no-JS, reduced-motion, coarse-pointer, keyboard, and user-paused
 *     fallback. Duplicate sets stay display:none.
 *   drift — JS-applied only on fine-pointer + motion-OK + not user-paused:
 *     overflow clipped, infinite CSS transform marquee over 3 identical sets.
 * Because drift is JS-applied, auto-motion can never ship without its pause
 * control (WCAG 2.2.2), and no-JS users get a working shelf.
 */
interface ProjectData {
  title: string;
  label?: string;
  gradient?: string;
  image?: string;
}

interface Props {
  projects: Array<{ id: string; data: ProjectData }>;
}

const { projects } = Astro.props;

const FALLBACK_GRADIENT = 'linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)';
const bgStyle = (data: ProjectData) =>
  data.image
    ? `background-image:url('${data.image}');background-size:cover;background-position:center;`
    : `background:${data.gradient || FALLBACK_GRADIENT};`;
---

<div
  class="rail"
  data-rail
  data-mode="shelf"
  data-reveal
  role="group"
  aria-label="Featured projects"
  tabindex="0"
>
  <div class="rail-track">
    {[0, 1, 2].map((set) => (
      <div class="rail-set" {...(set > 0 ? { 'aria-hidden': 'true' } : {})}>
        {projects.map((p) => (
          <a class="plate" href={`/projects/${p.id}/`} {...(set > 0 ? { tabindex: '-1' } : {})}>
            <div class="plate-bg" style={bgStyle(p.data)}></div>
            <div class="plate-scrim"></div>
            <div class="plate-text">
              {p.data.label && <p class="plate-label">{p.data.label}</p>}
              <p class="plate-title">{p.data.title}</p>
            </div>
          </a>
        ))}
      </div>
    ))}
  </div>
</div>
<div class="mx-auto max-w-[var(--max-w-content)] px-6 mt-8 flex items-baseline justify-between">
  <a href="/projects/" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)]">All projects →</a>
  <button
    type="button"
    data-rail-toggle
    hidden
    aria-pressed="false"
    aria-label="Pause carousel motion"
    class="font-mono text-[0.65rem] uppercase tracking-[0.16em] text-text-muted hover:text-text-primary cursor-pointer"
  >pause</button>
</div>

<style>
  .rail {
    padding-block: 8px; /* room for focus rings */
  }
  .rail:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 4px;
  }
  .rail[data-mode='shelf'] {
    overflow-x: auto;
    scrollbar-width: none;
    /* first plate aligns to the 1100px column */
    padding-inline: max(1.5rem, calc((100% - var(--max-w-content)) / 2));
  }
  .rail[data-mode='shelf']::-webkit-scrollbar {
    display: none;
  }
  .rail[data-mode='shelf'] .rail-set[aria-hidden] {
    display: none;
  }
  /* clip, NOT hidden — hidden lets focus set scrollLeft and permanently
     desyncs the transform seam */
  .rail[data-mode='drift'] {
    overflow: clip;
  }

  .rail-track {
    display: flex;
    width: max-content;
  }
  /* set pitch = 7×(w+g) exactly: 6 internal gaps + 1 trailing padding.
     NO gap on .rail-track — a track gap breaks the -1/3 seam math. */
  .rail-set {
    display: flex;
    gap: var(--plate-gap);
    padding-right: var(--plate-gap);
  }

  .rail { --plate-w: 280px; --plate-gap: 16px; --drift-dur: 95s; }
  @media (min-width: 640px) { .rail { --plate-w: 340px; --plate-gap: 20px; --drift-dur: 105s; } }
  @media (min-width: 1024px) { .rail { --plate-w: 420px; --plate-gap: 24px; --drift-dur: 125s; } }
  @media (min-width: 1536px) { .rail { --plate-w: 460px; --plate-gap: 28px; --drift-dur: 135s; } }

  @media (prefers-reduced-motion: no-preference) {
    .rail[data-mode='drift'] .rail-track {
      animation: rail-drift var(--drift-dur) linear infinite;
      will-change: transform;
    }
  }
  @keyframes rail-drift {
    to {
      transform: translate3d(calc(-100% / 3), 0, 0); /* exactly one set pitch */
    }
  }

  .rail[data-mode='drift']:hover .rail-track,
  .rail[data-mode='drift']:focus-within .rail-track,
  .rail.parked .rail-track,
  .rail.touch-still .rail-track {
    animation-play-state: paused;
  }

  /* No border, shadow, lift, zoom, filter, or mask — the dark plates against
     the page ground define their own edges; the hard crop at the viewport
     edge is the frame. */
  .plate {
    position: relative;
    display: block;
    flex-shrink: 0;
    width: var(--plate-w);
    aspect-ratio: 3 / 2;
    border-radius: 2px;
    overflow: hidden;
  }
  .plate:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }
  .plate-bg {
    position: absolute;
    inset: 0;
  }
  .plate-scrim {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 48%;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.72), transparent);
  }
  .plate-text {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
  }
  .plate-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 6px;
    transition: color 0.2s var(--ease-out);
  }
  .plate:hover .plate-label {
    color: rgba(255, 255, 255, 0.9);
  }
  .plate-title {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 600;
    line-height: 1.35;
    color: #fff;
  }
  @media (prefers-reduced-motion: reduce) {
    .plate-label {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    const rail = document.querySelector<HTMLElement>('[data-rail]');
    if (!rail) return;
    const toggle = document.querySelector<HTMLButtonElement>('[data-rail-toggle]');
    const fine = matchMedia('(pointer: fine) and (hover: hover)');
    const reduce = matchMedia('(prefers-reduced-motion: reduce)');
    const KEY = 'rail-drift';
    let paused = false;
    try {
      paused = localStorage.getItem(KEY) === 'paused';
    } catch {}
    const driftable = () => fine.matches && !reduce.matches;
    const apply = () => {
      rail.dataset.mode = driftable() && !paused ? 'drift' : 'shelf';
      if (toggle) {
        toggle.hidden = !driftable();
        toggle.textContent = paused ? 'drift' : 'pause';
        toggle.setAttribute('aria-pressed', String(paused));
        toggle.setAttribute('aria-label', paused ? 'Resume carousel motion' : 'Pause carousel motion');
      }
    };
    apply();
    toggle?.addEventListener('click', () => {
      paused = !paused;
      try {
        paused ? localStorage.setItem(KEY, 'paused') : localStorage.removeItem(KEY);
      } catch {}
      apply();
    });
    fine.addEventListener?.('change', apply);
    reduce.addEventListener?.('change', apply);

    // Keyboard: switch to shelf while focus is inside, reveal the focused plate.
    rail.addEventListener('focusin', (e) => {
      if (rail.dataset.mode === 'drift') rail.dataset.mode = 'shelf';
      (e.target as HTMLElement).scrollIntoView({ block: 'nearest', inline: 'nearest' });
    });
    rail.addEventListener('focusout', (e) => {
      if (!rail.contains((e as FocusEvent).relatedTarget as Node)) apply();
    });

    // Battery: park the compositor animation off-viewport.
    new IntersectionObserver(
      ([en]) => rail.classList.toggle('parked', !en!.isIntersecting),
      { rootMargin: '100px 0px' },
    ).observe(rail);

    // Hybrid touch-screen laptops in drift mode: a touch holds the bed still.
    let t = 0;
    rail.addEventListener(
      'pointerdown',
      (e) => {
        if (e.pointerType !== 'touch' || rail.dataset.mode !== 'drift') return;
        rail.classList.add('touch-still');
        clearTimeout(t);
        t = window.setTimeout(() => rail.classList.remove('touch-still'), 4000);
      },
      { passive: true },
    );
  })();
</script>
