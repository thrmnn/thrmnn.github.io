---
interface Props {
  title: string;
  authors: string[];
  venue: string;
  date: Date;
  doi?: string;
  pdfUrl?: string;
}

const { title, authors, venue, date, doi, pdfUrl } = Astro.props;
const year = date.getFullYear();
---

<div class="py-4 border-b border-border last:border-b-0">
  <p class="font-semibold text-text-primary leading-snug">{title}</p>
  <p class="text-sm text-text-muted mt-1">
    {authors.map((a) => (a === 'admin' ? 'T. Hermann' : a)).join(', ')}
  </p>
  <p class="text-sm text-text-muted mt-0.5">
    <span class="italic">{venue}</span> · {year}
  </p>
  {(doi || pdfUrl) && (
    <div class="flex gap-3 mt-2">
      {doi && (
        <a href={`https://doi.org/${doi}`} class="text-xs text-accent hover:text-accent-hover font-medium">
          DOI
        </a>
      )}
      {pdfUrl && (
        <a href={pdfUrl} class="text-xs text-accent hover:text-accent-hover font-medium">
          PDF
        </a>
      )}
    </div>
  )}
</div>
