---
/**
 * ThemeToggle — switches between dark and light mode.
 * Displays the moon icon when the current theme is light (click to go dark)
 * and the sun icon when the current theme is dark (click to go light).
 *
 * Relies on the anti-FOUC inline script in BaseLayout.astro to set
 * `data-theme` on <html> before first paint.
 */
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark/light mode"
  class="relative w-9 h-9 flex items-center justify-center rounded-lg
         text-text-muted hover:text-text-secondary
         hover:bg-bg-elevated
         border border-transparent hover:border-border
         transition-all duration-200 cursor-pointer"
>
  <!-- Sun icon — visible in dark mode (click to switch to light) -->
  <svg
    class="theme-icon-sun w-[18px] h-[18px] absolute"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32l1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41m11.32-11.32l1.41-1.41" />
  </svg>

  <!-- Moon icon — visible in light mode (click to switch to dark) -->
  <svg
    class="theme-icon-moon w-[18px] h-[18px] absolute"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    viewBox="0 0 24 24"
    aria-hidden="true"
  >
    <path d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75 9.75 9.75 0 0 1 8.25 6c0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 12a9.75 9.75 0 0 0 16.5 7.125 9.72 9.72 0 0 0 2.252-4.123Z" />
  </svg>
</button>

<style>
  /* Default (dark mode): show sun, hide moon */
  .theme-icon-sun {
    opacity: 1;
    transform: rotate(0deg) scale(1);
    transition: opacity 0.25s ease, transform 0.35s ease;
  }
  .theme-icon-moon {
    opacity: 0;
    transform: rotate(-45deg) scale(0.75);
    transition: opacity 0.25s ease, transform 0.35s ease;
  }

  /* Light mode: show moon, hide sun */
  :global([data-theme="light"]) .theme-icon-sun {
    opacity: 0;
    transform: rotate(45deg) scale(0.75);
  }
  :global([data-theme="light"]) .theme-icon-moon {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  /* Also handle OS-level light preference when no data-theme is set */
  @media (prefers-color-scheme: light) {
    :global(:root:not([data-theme])) .theme-icon-sun {
      opacity: 0;
      transform: rotate(45deg) scale(0.75);
    }
    :global(:root:not([data-theme])) .theme-icon-moon {
      opacity: 1;
      transform: rotate(0deg) scale(1);
    }
  }
</style>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const current = html.getAttribute('data-theme');

      // Determine the effective theme right now
      const isDark =
        current === 'dark' ||
        (!current && !window.matchMedia('(prefers-color-scheme: light)').matches);

      const next = isDark ? 'light' : 'dark';

      html.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);

      btn.setAttribute(
        'aria-label',
        next === 'dark' ? 'Switch to light mode' : 'Switch to dark mode',
      );
    });
  }

  // Run on initial load
  initThemeToggle();

  // Re-run after Astro client-side navigations (View Transitions)
  document.addEventListener('astro:after-swap', initThemeToggle);
</script>
