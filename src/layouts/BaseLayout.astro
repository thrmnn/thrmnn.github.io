---
import '../styles/global.css';
import { siteConfig } from '../data/site';
import { author } from '../data/author';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'profile' | 'article';
  articleJsonLd?: Record<string, unknown>;
}

const { title, description, image, ogType = 'website', articleJsonLd } = Astro.props;
const pageTitle = title ? `${title} — ${siteConfig.title}` : siteConfig.title;
const pageDescription = description || siteConfig.description;
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href;
const ogImage = new URL(image || siteConfig.ogImage, siteConfig.url).href;

const socialUrls = author.social
  .filter((s) => s.icon !== 'email')
  .map((s) => s.href);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": author.name,
  "jobTitle": author.role,
  "url": siteConfig.url,
  "image": new URL('/avatar.webp', siteConfig.url).href,
  "email": author.email,
  "worksFor": {
    "@type": "Organization",
    "name": author.affiliation,
  },
  "sameAs": socialUrls,
  "alumniOf": [...new Set(author.education.map((edu) => edu.institution))].map((name) => ({
    "@type": "CollegeOrUniversity",
    "name": name,
  })),
  "knowsAbout": [
    "Computer Vision",
    "Perception Systems",
    "Sensor Fusion",
    "LiDAR Processing",
    "3D Reconstruction",
    "Autonomous Navigation",
    "Robot Operating System (ROS)",
    "Deep Learning",
    "Edge Deployment",
    "MLOps",
    "PyTorch",
    "C++",
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": author.role,
    "occupationLocation": {
      "@type": "Place",
      "name": author.experience[0]?.location,
    },
    "description": author.experience[0]?.summary,
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://plausible.io" />
    <meta name="generator" content={Astro.generator} />

    <!-- Anti-FOUC: set data-theme synchronously before first paint -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.setAttribute('data-theme', stored);
        }
        // When no stored preference, let :root / @media (prefers-color-scheme)
        // in CSS handle it — no data-theme attribute needed.
      })();
    </script>

    <!-- Boot intro: one-time scan-line sequence, first load per session -->
    <style is:inline>
      #boot-intro {
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: #0a0a0a;
        color: #f5f5f5;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.3s ease;
      }
      #boot-intro.boot-light { background: #fafafa; color: #171717; }
      #boot-intro.boot-out { opacity: 0; pointer-events: none; }
      #boot-intro .boot-mark {
        opacity: 0;
        animation: boot-mark-in 0.88s ease forwards;
      }
      #boot-intro .boot-scan {
        position: absolute;
        left: 0;
        right: 0;
        top: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, #3b82f6 35%, #8b5cf6 65%, transparent);
        box-shadow: 0 0 26px 5px rgba(59, 130, 246, 0.45);
        animation: boot-sweep 0.86s ease-in-out forwards;
      }
      @keyframes boot-sweep {
        0%   { transform: translateY(0); opacity: 0; }
        12%  { opacity: 1; }
        85%  { opacity: 1; }
        100% { transform: translateY(100vh); opacity: 0; }
      }
      @keyframes boot-mark-in {
        0%   { opacity: 0; transform: scale(0.92); }
        32%  { opacity: 1; }
        78%  { opacity: 1; transform: scale(1); }
        100% { opacity: 0; transform: scale(1.03); }
      }
    </style>
    <script is:inline>
      (function () {
        try {
          var KEY = 'introSeen';
          if (sessionStorage.getItem(KEY)) return;
          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            sessionStorage.setItem(KEY, '1');
            return;
          }
          sessionStorage.setItem(KEY, '1');
          var dt = document.documentElement.getAttribute('data-theme');
          var light = dt === 'light' ||
            (!dt && window.matchMedia('(prefers-color-scheme: light)').matches);
          var o = document.createElement('div');
          o.id = 'boot-intro';
          o.setAttribute('aria-hidden', 'true');
          if (light) o.className = 'boot-light';
          o.innerHTML =
            '<svg class="boot-mark" viewBox="0 0 32 32" width="76" height="76" fill="none">' +
            '<defs><linearGradient id="bI" x1="0" y1="0" x2="1" y2="1">' +
            '<stop offset="0" stop-color="#3b82f6"/><stop offset="1" stop-color="#8b5cf6"/>' +
            '</linearGradient></defs>' +
            '<g stroke="url(#bI)" stroke-width="2.4" stroke-linecap="round">' +
            '<line x1="7" y1="9.5" x2="25" y2="9.5"/><line x1="16" y1="9.5" x2="16" y2="24"/></g>' +
            '<g fill="currentColor">' +
            '<circle cx="7" cy="9.5" r="2.7"/><circle cx="16" cy="9.5" r="2.7"/>' +
            '<circle cx="25" cy="9.5" r="2.7"/><circle cx="16" cy="24" r="2.7"/></g></svg>' +
            '<div class="boot-scan"></div>';
          document.documentElement.appendChild(o);
          var done = false;
          function end() {
            if (done) return;
            done = true;
            o.classList.add('boot-out');
            setTimeout(function () { if (o.parentNode) o.parentNode.removeChild(o); }, 320);
          }
          var timer = setTimeout(end, 880);
          ['pointerdown', 'keydown', 'wheel', 'touchstart'].forEach(function (ev) {
            window.addEventListener(ev, function () { clearTimeout(timer); end(); },
              { once: true, passive: true });
          });
        } catch (e) {}
      })();
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="author" content={author.name} />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:site_name" content={siteConfig.title} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={pageTitle} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {articleJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    )}

    <!-- Analytics -->
    {import.meta.env.PROD && siteConfig.analytics?.plausible?.enabled && (
      <script
        defer
        data-domain={siteConfig.analytics.plausible.domain}
        src="https://plausible.io/js/script.js"
      />
    )}

    <!-- Font (self-hosted Space Grotesk; latin preloaded, latin-ext lazy via unicode-range) -->
    <link rel="preload" href="/fonts/space-grotesk-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />
  </body>
</html>
