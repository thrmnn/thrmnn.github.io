---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: 'website' | 'profile' | 'article';
  articleJsonLd?: Record<string, unknown>;
  register?: 'cartesian' | 'tropical';
}

const { title, description, image, ogType, articleJsonLd, register } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  image={image}
  ogType={ogType}
  articleJsonLd={articleJsonLd}
  register={register}
>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
