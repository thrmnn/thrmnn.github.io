---
import PageLayout from '../layouts/PageLayout.astro';

const pages = [
  { label: 'Work', href: '/work', note: 'Research and engineering projects.' },
  { label: 'Writing', href: '/writing', note: 'Essays and field notes.' },
  { label: 'Now', href: '/now', note: 'What I am working on this month.' },
  { label: 'About', href: '/about', note: 'Trajectory and languages.' },
];
---

<PageLayout title="404" description="Page not found.">
  <section class="page-wrap notfound">
    <span class="mono-caption">404</span>
    <h1 class="notfound-title">This page is not here.</h1>
    <p class="notfound-lede">It may have moved, been renamed, or never existed at all.</p>

    <ul class="notfound-list">
      {
        pages.map((p) => (
          <li>
            <a href={p.href} class="notfound-link">
              <span class="notfound-label">{p.label}</span>
              <span class="notfound-note">{p.note}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>

<style>
  .notfound {
    padding-block: clamp(3rem, 8vw, 5rem) var(--space-section);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 60ch;
  }
  .notfound-title {
    font-size: var(--text-display-md);
    line-height: 1.1;
  }
  .notfound-lede {
    color: var(--color-ink-soft);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    margin-bottom: 1rem;
  }
  .notfound-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }
  .notfound-list li {
    border-bottom: 1px solid var(--color-rule);
  }
  .notfound-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 0;
    color: var(--color-ink);
    text-decoration: none;
    transition:
      padding-left 250ms ease,
      color 250ms ease;
  }
  .notfound-link:hover {
    padding-left: 0.5rem;
    color: var(--color-accent);
  }
  .notfound-label {
    font-family: var(--font-cartesian);
    font-size: var(--text-body-lg);
    font-weight: 600;
  }
  .notfound-note {
    color: var(--color-ink-muted);
    font-size: var(--text-body-sm);
  }
</style>
