---
import PageLayout from '../layouts/PageLayout.astro';
import MonoRow from '../components/typography/MonoRow.astro';
import SectionRule from '../components/composition/SectionRule.astro';
import Marginalia from '../components/composition/Marginalia.astro';
import { author } from '../data/author';
---

<PageLayout title="Contact" description="Email and handles for Théo Alessandro Hermann.">
  <section class="contact grid-cartesian">
    <div class="col-1-13 contact-head">
      <MonoRow pieces={['Contact', 'Rio']} />
    </div>
    <h1 class="col-1-9 contact-title">Reach out.</h1>
    <p class="col-3-9 contact-lede">
      For research conversations, consulting at the intersection of built environment and AI
      infrastructure, or anything that resembles either.
    </p>

    <div class="col-1-13">
      <SectionRule align="start">Channels</SectionRule>
    </div>

    <dl class="col-1-9 contact-grid">
      <div class="contact-row">
        <dt class="mono-caption">Email</dt>
        <dd><a href={`mailto:${author.email}`}>{author.email}</a></dd>
      </div>
      <div class="contact-row">
        <dt class="mono-caption">Public</dt>
        <dd><a href={author.links.twitter} rel="me noopener">@{author.handles.public}</a></dd>
      </div>
      <div class="contact-row">
        <dt class="mono-caption">Technical</dt>
        <dd><a href={author.links.github} rel="me noopener">@{author.handles.technical}</a></dd>
      </div>
      <div class="contact-row">
        <dt class="mono-caption">LinkedIn</dt>
        <dd><a href={author.links.linkedin} rel="me noopener">/in/{author.handles.public}</a></dd>
      </div>
      <div class="contact-row">
        <dt class="mono-caption">Based</dt>
        <dd>{author.location}</dd>
      </div>
    </dl>

    <aside class="col-10-13 contact-margin">
      <Marginalia voice="mono">
        Replies within a few days. No noisy newsletter.
      </Marginalia>
    </aside>
  </section>
</PageLayout>

<style>
  .contact {
    padding-block: clamp(2.5rem, 6vw, 4rem) var(--space-section);
    row-gap: var(--s-6);
  }
  .contact-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .contact-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-lg);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0;
  }
  .contact-lede {
    font-family: var(--font-body);
    color: var(--color-ink-soft);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    margin: 0;
    margin-top: var(--s-4);
  }
  .contact-grid {
    border-top: 1px solid var(--color-rule);
    margin: 0;
    padding: 0;
  }
  .contact-row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: var(--s-6);
    align-items: baseline;
    padding: var(--s-4) 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .contact-row dt {
    margin: 0;
  }
  .contact-row dd {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink);
  }
  .contact-row a {
    color: var(--color-ink);
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 1px;
    text-decoration: none;
    transition:
      color 200ms ease,
      border-color 200ms ease;
  }
  .contact-row a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .contact-margin {
    align-self: end;
    padding-bottom: var(--s-6);
  }
  @media (max-width: 520px) {
    .contact-row {
      grid-template-columns: 1fr;
      gap: var(--s-1);
    }
  }
</style>
