---
import PageLayout from '../layouts/PageLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import FeaturedStrip from '../components/FeaturedStrip.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../data/site';

const writingAll = await getCollection('writing');
const latestWriting = writingAll
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 1)[0];
---

<PageLayout description={siteConfig.description}>
  <section class="hero page-wrap">
    <Wordmark size="lg" as="static" />
    <p class="positioning">
      Researcher and builder. <span class="positioning-em">MIT Senseable Rio.</span>
      Urban science, robotics, and what comes next.
    </p>
  </section>

  <div class="page-wrap">
    <FeaturedStrip />

    {
      latestWriting && (
        <section class="latest-writing">
          <div class="featured-head">
            <span class="mono-caption">Latest writing</span>
            <a href="/writing" class="featured-all">
              All writing →
            </a>
          </div>
          <a href={`/writing/${latestWriting.id}`} class="writing-card">
            <span class="mono-caption">
              {latestWriting.data.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </span>
            <h3 class="writing-title">{latestWriting.data.title}</h3>
            <p class="writing-summary">{latestWriting.data.summary}</p>
          </a>
        </section>
      )
    }
  </div>
</PageLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6rem) 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    overflow-wrap: break-word;
  }
  .positioning {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.55;
    color: var(--color-ink-soft);
    max-width: 38ch;
  }
  .positioning-em {
    color: var(--color-ink);
    font-weight: 500;
  }

  .latest-writing {
    margin-top: var(--space-section);
  }
  .featured-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-rule);
  }
  .featured-all {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .featured-all:hover {
    color: var(--color-accent);
  }

  .writing-card {
    display: block;
    text-decoration: none;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-rule);
    color: var(--color-ink);
    transition: border-color 250ms ease;
  }
  .writing-card:hover {
    border-bottom-color: var(--color-rule-strong);
  }
  .writing-title {
    font-family: var(--font-cartesian);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 0.5rem;
    letter-spacing: -0.015em;
  }
  .writing-card:hover .writing-title {
    color: var(--color-accent);
  }
  .writing-summary {
    color: var(--color-ink-muted);
    margin-top: 0.4rem;
    max-width: 62ch;
    font-size: 0.98rem;
  }
</style>
