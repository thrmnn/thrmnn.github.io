---
import PageLayout from '../layouts/PageLayout.astro';
import FeaturedStrip from '../components/FeaturedStrip.astro';
import Marginalia from '../components/composition/Marginalia.astro';
import SectionRule from '../components/composition/SectionRule.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../data/site';
import { author } from '../data/author';

const writingAll = await getCollection('writing');
const latestWriting = writingAll
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 1)[0];

const projectCount = (await getCollection('projects')).filter((p) => p.data.featured).length;
const scrollLabel = `↓ CURRENT WORK · ${String(projectCount).padStart(2, '0')} PROJECT${projectCount === 1 ? '' : 'S'}`;
---

<PageLayout description={siteConfig.description}>
  <section class="hero">
    <div class="hero-grid grid-cartesian">
      <div class="hero-wordmark col-1-7">
        <h1 class="wordmark-hero" aria-label={author.name}>
          Théo<br />
          <em>Alessandro</em><br />
          Hermann
        </h1>
      </div>
      <aside class="hero-meta col-10-12">
        <p class="mono-caption">RIO · 2026</p>
        <hr class="hero-rule" />
        <p class="hero-positioning">
          Researcher and builder.<br />
          MIT Senseable Rio.<br />
          Urban science, robotics,<br />
          and what comes next.
        </p>
        <hr class="hero-rule" />
        <p class="mono-caption">FR · BR · 4 LANGUAGES</p>
      </aside>
    </div>
    <p class="hero-scroll mono-caption">{scrollLabel}</p>
  </section>

  <div class="page-wrap below-hero">
    <FeaturedStrip />

    {
      latestWriting && (
        <section class="writing-section">
          <SectionRule>Writing</SectionRule>
          <div class="grid-cartesian writing-grid">
            <a href={`/writing/${latestWriting.id}`} class="writing-card col-1-8">
              <span class="mono-caption">
                {latestWriting.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
              <h3 class="writing-title">{latestWriting.data.title}</h3>
              <p class="writing-summary">{latestWriting.data.summary}</p>
            </a>
            <aside class="col-10-12 writing-meta">
              <Marginalia voice="mono">Notes & essays — irregular cadence</Marginalia>
            </aside>
          </div>
        </section>
      )
    }
  </div>
</PageLayout>

<style>
  /* Hero — 100vh asymmetric composition (Phase 4.7 A3).
     90vh leaves a sliver of the next section visible at the bottom,
     hinting at scroll without showing actual content. */
  .hero {
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-block: var(--s-16);
    position: relative;
  }
  .hero-grid {
    width: 100%;
    align-items: start;
    padding-top: 8vh;
  }
  .hero-wordmark {
    /* Wordmark breathes at top of viewport; no extra padding. */
  }
  .hero-meta {
    padding-top: var(--s-20);
    /* Asymmetric offset — meta starts well below the wordmark's baseline. */
  }
  .hero-rule {
    border: 0;
    border-top: 1px solid var(--color-rule);
    margin: var(--s-4) 0;
  }
  .hero-positioning {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: 1.45;
    color: var(--color-ink-soft);
    margin-block: var(--s-4);
  }
  .hero-scroll {
    text-align: left;
    color: var(--color-ink-muted);
    padding-bottom: var(--s-4);
    margin: 0;
  }
  @media (max-width: 719px) {
    .hero {
      min-height: 80vh;
      padding-block: var(--s-12);
    }
    .hero-grid {
      padding-top: var(--s-12);
    }
    .hero-meta {
      padding-top: var(--s-8);
    }
  }

  /* Wordmark-hero — THE typographic moment (Phase 4.7 A1).
     Cartesian display face (Space Grotesk) at --text-hero scale; the
     <em> middle line is italic and lighter for tension. Aria label on
     the h1 preserves the spoken name. */
  .wordmark-hero {
    font-family: var(--font-cartesian);
    font-size: var(--text-hero);
    font-weight: 500;
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0;
  }
  .wordmark-hero em {
    font-style: italic;
    font-weight: 300;
    letter-spacing: -0.04em;
  }

  /* Below-fold sections — sit below the hero, only visible once scrolled. */
  .below-hero {
    margin-top: var(--space-section);
  }

  .writing-section {
    margin-top: var(--space-section);
  }
  .writing-grid {
    padding-inline: 0;
    max-width: none;
  }

  .writing-card {
    display: block;
    text-decoration: none;
    padding: var(--s-4) 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    color: var(--color-ink);
    transition: border-color 250ms ease;
  }
  .writing-card:hover {
    border-color: var(--color-rule-strong);
  }
  .writing-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-sm);
    font-weight: 600;
    margin-top: var(--s-2);
    letter-spacing: -0.015em;
  }
  .writing-card:hover .writing-title {
    color: var(--color-accent);
  }
  .writing-summary {
    color: var(--color-ink-muted);
    margin-top: var(--s-2);
    max-width: 62ch;
    font-size: var(--text-body-sm);
  }
  .writing-meta {
    align-self: center;
  }
</style>
