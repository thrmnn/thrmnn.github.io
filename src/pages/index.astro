---
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCarousel from '../components/ui/ProjectCarousel.astro';
import NewsItem from '../components/ui/NewsItem.astro';
import Button from '../components/ui/Button.astro';
import SocialIcon from '../components/ui/SocialIcon.astro';
import { author } from '../data/author';
import { newsItems } from '../data/news';
import { getCollection } from 'astro:content';

// Featured first, then the rest — the carousel surfaces the whole portfolio.
const allProjects = (await getCollection('projects')).filter((p) => !p.data.draft);
const carouselProjects = [
  ...allProjects
    .filter((p) => p.data.featuredOrder !== undefined)
    .sort((a, b) => a.data.featuredOrder! - b.data.featuredOrder!),
  ...allProjects.filter((p) => p.data.featuredOrder === undefined),
];

const mailto = `mailto:${author.email}`;
---

<PageLayout ogType="profile">
  <!-- Hero -->
  <section id="home" class="hero-section">
    <div class="hero-grid">
      <div class="hero-type">
        <h1
          class="hero-name"
          data-reveal
          style="--reveal-d: 0;"
        >
          {author.name}
        </h1>
        <p class="hero-positioning" data-reveal style="--reveal-d: 1;">
          Researcher at <strong>MIT Senseable City Lab Rio</strong> — 3D digital twins of favelas for public health. Building open-source robotics. Consulting in perception and AI-agent infrastructure.
        </p>
      </div>
      <div class="hero-artifact" data-reveal style="--reveal-d: 1;">
        <div class="artifact-frame">
          <canvas
            class="favela-scrubber"
            aria-label="Rotating point-cloud samples from real research datasets: Vidigal favela, the Amsterdam tree census, and a De Pijp LiDAR tile. Drag to rotate."
          ></canvas>
          <div class="artifact-corners" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </div>
        </div>
        <div class="artifact-chips mt-3" role="group" aria-label="Choose a dataset">
          <button type="button" class="artifact-chip is-active" data-artifact-chip data-url="/data/vidigal-rooftops.bin" aria-pressed="true">vidigal · rio</button>
          <button type="button" class="artifact-chip" data-artifact-chip data-url="/data/ams-trees.bin" aria-pressed="false">tree census · ams</button>
          <button type="button" class="artifact-chip" data-artifact-chip data-url="/data/depijp-lidar.bin" aria-pressed="false">lidar · de pijp</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Biography -->
  <section id="about" class="py-[var(--space-section)] bg-bg-accent">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <div class="flex flex-col md:flex-row gap-12 items-start">
      <div class="shrink-0 mx-auto md:mx-0" data-reveal style="--reveal-d: 1;">
        <div class="avatar-ring rounded-full p-[3px]">
          <img
            src="/avatar.webp"
            alt={author.name}
            width="180"
            height="180"
            loading="eager"
            decoding="async"
            class="rounded-full block"
          />
        </div>
        <div class="mt-4 text-center md:text-left">
          <p class="text-xl font-bold text-text-primary">{author.name}</p>
          <p class="text-sm text-text-muted">{author.role}</p>
          <p class="text-sm text-text-muted">{author.affiliation}</p>
        </div>
        <div class="flex gap-3 mt-4 justify-center md:justify-start">
          {author.social.map((s) => (
            <a
              href={s.href}
              {...(s.icon !== 'email' ? { target: '_blank', rel: 'noopener' } : {})}
              class="text-text-muted hover:text-text-secondary transition-colors"
              aria-label={s.label}
              title={s.label}
            >
              <SocialIcon type={s.icon as 'email' | 'github' | 'linkedin' | 'scholar'} />
            </a>
          ))}
        </div>
      </div>
      <div class="flex-1 max-w-prose" data-reveal style="--reveal-d: 2;">
        {author.bio.map((paragraph) => (
          <p class="text-text-secondary leading-relaxed mb-4" set:html={paragraph} />
        ))}
        <div class="mt-6">
          <Button href="/cv/" variant="secondary">Full CV</Button>
        </div>
      </div>
      </div>
    </div>
  </section>

  <!-- Featured Work (promoted above Latest for recruiter-first funnel) -->
  <section id="projects" class="py-[var(--space-section)] bg-bg-secondary">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h2 class="text-3xl font-bold text-text-primary mb-8" data-reveal>Featured Work</h2>
      <ProjectCarousel projects={carouselProjects} />
    </div>
  </section>

  <!-- Latest -->
  <section id="news" class="py-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h2 class="text-3xl font-bold text-text-primary mb-8" data-reveal>Latest</h2>
      <div class="max-w-xl">
        {newsItems.slice(0, 3).map((item, i) => (
          <NewsItem date={item.date} text={item.text} index={i} />
        ))}
      </div>
      <p class="mt-6" data-reveal>
        <a href="/now/" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)]">
          Full timeline & what I'm doing now →
        </a>
      </p>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact-section relative py-[var(--space-section)] overflow-hidden">
    <div class="contact-bg absolute inset-0"></div>
    <div class="relative z-10 mx-auto max-w-[var(--max-w-content)] px-6 text-center">
      <h2 class="text-3xl font-bold text-text-primary mb-4" data-reveal>Let's Talk</h2>
      <p class="text-text-secondary mb-10 max-w-lg mx-auto text-lg" data-reveal style="--reveal-d: 2;">
        Consulting in <strong class="text-text-primary">perception</strong> and <strong class="text-text-primary">AI-agent infrastructure</strong>, and research collaboration — <a href="/consulting/" class="text-[var(--color-link)] hover:text-[var(--color-link-hover)] underline-offset-4 underline decoration-1">see engagement scopes →</a>
      </p>
      <div class="flex justify-center gap-3 sm:gap-5 flex-wrap" data-reveal style="--reveal-d: 3;">
        <Button href="https://cal.com/theo-hermann-aaa7tm" external>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          Book a 20-min intro
        </Button>
        <Button href={mailto} variant="secondary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          E-mail
        </Button>
        <Button href="https://www.linkedin.com/in/theohermann-epfl/" variant="secondary" external>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </Button>
      </div>
    </div>
  </section>

  <script>
    import { initFavelaScrubber } from '../scripts/favela-scrubber.ts';
    const canvas = document.querySelector('.favela-scrubber') as HTMLCanvasElement | null;
    if (canvas) initFavelaScrubber(canvas);
  </script>
</PageLayout>
