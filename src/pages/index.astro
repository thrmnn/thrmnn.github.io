---
import PageLayout from '../layouts/PageLayout.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';
import NewsItem from '../components/ui/NewsItem.astro';
import PublicationEntry from '../components/ui/PublicationEntry.astro';
import Button from '../components/ui/Button.astro';
import SocialIcon from '../components/ui/SocialIcon.astro';
import { author } from '../data/author';
import { newsItems } from '../data/news';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const featuredProjects = [
  {
    title: 'Urban Digital Twin for Airborne Disease Modeling',
    label: 'MIT Senseable City Lab · 2025',
    metric: '10-person team · CFD pipeline · Deployed',
    tags: ['LiDAR', 'OpenFOAM', 'Blender', 'Python', '3D Reconstruction'],
    detail: 'Leading interdisciplinary team (MIT + UFMG + TU Delft) building high-fidelity 3D digital twins of Rio\'s favelas from terrestrial LiDAR. Reconstructions feed CFD simulations of airborne pathogen dispersion for public health interventions.',
    href: 'https://senseablerio.mit.edu/',
    gradient: 'linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%)',
  },
  {
    title: 'Urban Tree Census at Scale: Aerial LiDAR + ML',
    label: "Master's Thesis · EPFL + MIT · 2024",
    metric: '12,350 trees classified · Paper under review (Springer Nature)',
    tags: ['LiDAR', 'XGBoost', 'Random Forest', 'GeoPandas', 'Remote Sensing'],
    detail: 'First large-scale automated tree census of informal settlements. Aerial LiDAR survey across São Paulo with ML-driven species classification and canopy health assessment.',
    href: 'https://senseable.mit.edu/',
    gradient: 'linear-gradient(135deg, #0d3b0d 0%, #1a472a 50%, #2d6a4f 100%)',
  },
  {
    title: 'Perception Stack for Autonomous Canal Boats',
    label: 'Roboat (MIT Spinoff) · 2024',
    metric: '<30ms inference · 100+ hrs maritime data · Deployed on vessels',
    tags: ['YOLO', 'PyTorch', 'Jetson Orin', 'DVC', 'MLOps', 'ROS2'],
    detail: 'End-to-end camera-first perception replacing expensive LiDAR-only pipeline. Detection, multi-object tracking, and point cloud segmentation on edge hardware, deployed on physical vessels in Amsterdam.',
    href: 'https://roboat.ai',
    gradient: 'linear-gradient(135deg, #1a1a3e 0%, #2a2a5e 50%, #3a3a7e 100%)',
  },
];
---

<PageLayout ogType="profile">
  <!-- Hero -->
  <section class="hero-section relative min-h-[70vh] sm:min-h-[85vh] flex items-center justify-center overflow-hidden">
    <!-- Animated gradient background -->
    <div class="absolute inset-0 hero-gradient">
      <!-- Grid overlay -->
      <div class="hero-grid absolute inset-0"></div>
      <!-- Radial spotlight behind text -->
      <div class="hero-spotlight absolute inset-0"></div>
      <!-- Floating particles -->
      <div class="hero-particle hero-particle-1"></div>
      <div class="hero-particle hero-particle-2"></div>
      <div class="hero-particle hero-particle-3"></div>
      <!-- Bottom fade to bg-primary -->
      <div class="hero-bottom-fade absolute inset-x-0 bottom-0 h-[40%]"></div>
    </div>
    <div class="relative z-10 text-center px-6 max-w-3xl">
      <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-3 mb-4">
        {['Perception', 'Autonomous Systems', '3D Reconstruction', 'Robotics'].map((tag, i) => (
          <span
            class="hero-tag text-xs text-text-muted uppercase tracking-wider px-3 py-1 rounded-full border border-border"
            style={`font-family: var(--font-display); animation-delay: ${i * 0.12}s;`}
          >
            {tag}
          </span>
        ))}
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-text-primary tracking-tight" style="font-family: var(--font-display);">
        Théo Hermann
      </h1>
      <p class="mt-6 text-lg text-text-secondary max-w-xl mx-auto">
        Robotics engineer building perception and autonomy systems that ship to the real world. Currently at MIT Senseable City Lab.
      </p>
      <div class="mt-10 flex items-center justify-center gap-4 flex-wrap">
        <Button href="/projects">View Work</Button>
        <Button href="/resume.pdf" variant="secondary">Download CV</Button>
      </div>
    </div>
  </section>

  <style>
    /* --- Hero tag stagger --- */
    @keyframes tag-enter {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .hero-tag {
      opacity: 0;
      animation: tag-enter 0.5s ease-out forwards;
    }

    /* --- Hero gradient animation --- */
    @keyframes hero-shift {
      0% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
      100% {
        background-position: 0% 50%;
      }
    }

    .hero-gradient {
      background: linear-gradient(
        135deg,
        #0c0c1d 0%,
        #111638 20%,
        #16143a 35%,
        #0e2248 50%,
        #1a1445 65%,
        #141230 80%,
        #0c0c1d 100%
      );
      background-size: 300% 300%;
      animation: hero-shift 20s ease infinite;
    }

    :global([data-theme="light"]) .hero-gradient {
      background: linear-gradient(
        135deg,
        #e8edf5 0%,
        #dce4f5 20%,
        #d4ddf2 35%,
        #cdd8f0 50%,
        #d4ddf2 65%,
        #dce4f5 80%,
        #e8edf5 100%
      );
      background-size: 300% 300%;
    }

    @media (prefers-color-scheme: light) {
      :global(:root:not([data-theme])) .hero-gradient {
        background: linear-gradient(
          135deg,
          #e8edf5 0%,
          #dce4f5 20%,
          #d4ddf2 35%,
          #cdd8f0 50%,
          #d4ddf2 65%,
          #dce4f5 80%,
          #e8edf5 100%
        );
        background-size: 300% 300%;
      }
    }

    /* --- Grid pattern --- */
    .hero-grid {
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.07) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.07) 1px, transparent 1px);
      background-size: 48px 48px;
      mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
      -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
    }

    :global([data-theme="light"]) .hero-grid {
      background-image:
        linear-gradient(rgba(0, 0, 0, 0.06) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
    }

    @media (prefers-color-scheme: light) {
      :global(:root:not([data-theme])) .hero-grid {
        background-image:
          linear-gradient(rgba(0, 0, 0, 0.06) 1px, transparent 1px),
          linear-gradient(90deg, rgba(0, 0, 0, 0.06) 1px, transparent 1px);
      }
    }

    /* --- Radial spotlight behind text --- */
    .hero-spotlight {
      background: radial-gradient(
        ellipse 50% 40% at 50% 48%,
        rgba(59, 130, 246, 0.08) 0%,
        rgba(99, 102, 241, 0.04) 40%,
        transparent 70%
      );
    }

    :global([data-theme="light"]) .hero-spotlight {
      background: radial-gradient(
        ellipse 50% 40% at 50% 48%,
        rgba(59, 130, 246, 0.12) 0%,
        rgba(99, 102, 241, 0.06) 40%,
        transparent 70%
      );
    }

    @media (prefers-color-scheme: light) {
      :global(:root:not([data-theme])) .hero-spotlight {
        background: radial-gradient(
          ellipse 50% 40% at 50% 48%,
          rgba(59, 130, 246, 0.12) 0%,
          rgba(99, 102, 241, 0.06) 40%,
          transparent 70%
        );
      }
    }

    /* --- Bottom fade to page background --- */
    .hero-bottom-fade {
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(10, 10, 10, 0.4) 30%,
        rgba(10, 10, 10, 0.8) 60%,
        var(--color-bg-primary) 100%
      );
    }

    :global([data-theme="light"]) .hero-bottom-fade {
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(250, 250, 250, 0.4) 30%,
        rgba(250, 250, 250, 0.8) 60%,
        var(--color-bg-primary) 100%
      );
    }

    @media (prefers-color-scheme: light) {
      :global(:root:not([data-theme])) .hero-bottom-fade {
        background: linear-gradient(
          to bottom,
          transparent 0%,
          rgba(250, 250, 250, 0.4) 30%,
          rgba(250, 250, 250, 0.8) 60%,
          var(--color-bg-primary) 100%
        );
      }
    }

    /* --- Floating particles --- */
    .hero-particle {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      will-change: transform, opacity;
    }

    .hero-particle-1 {
      width: 4px;
      height: 4px;
      background: rgba(59, 130, 246, 0.35);
      box-shadow: 0 0 8px 2px rgba(59, 130, 246, 0.15);
      top: 28%;
      left: 18%;
      animation: particle-float-1 14s ease-in-out infinite;
    }

    .hero-particle-2 {
      width: 3px;
      height: 3px;
      background: rgba(139, 92, 246, 0.3);
      box-shadow: 0 0 6px 2px rgba(139, 92, 246, 0.12);
      top: 55%;
      right: 22%;
      animation: particle-float-2 18s ease-in-out infinite;
    }

    .hero-particle-3 {
      width: 2.5px;
      height: 2.5px;
      background: rgba(99, 102, 241, 0.25);
      box-shadow: 0 0 6px 2px rgba(99, 102, 241, 0.1);
      top: 38%;
      right: 35%;
      animation: particle-float-3 22s ease-in-out infinite;
    }

    @keyframes particle-float-1 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.4;
      }
      25% {
        transform: translate(30px, -20px);
        opacity: 0.7;
      }
      50% {
        transform: translate(-15px, -40px);
        opacity: 0.3;
      }
      75% {
        transform: translate(20px, -10px);
        opacity: 0.6;
      }
    }

    @keyframes particle-float-2 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.3;
      }
      33% {
        transform: translate(-25px, 20px);
        opacity: 0.6;
      }
      66% {
        transform: translate(20px, -30px);
        opacity: 0.35;
      }
    }

    @keyframes particle-float-3 {
      0%, 100% {
        transform: translate(0, 0);
        opacity: 0.25;
      }
      20% {
        transform: translate(15px, 25px);
        opacity: 0.5;
      }
      40% {
        transform: translate(-20px, 10px);
        opacity: 0.3;
      }
      60% {
        transform: translate(-10px, -20px);
        opacity: 0.55;
      }
      80% {
        transform: translate(25px, -5px);
        opacity: 0.3;
      }
    }
  </style>

  <style>
    .avatar-ring {
      background: linear-gradient(135deg, #3b82f6, #8b5cf6, #3b82f6);
      background-size: 200% 200%;
      animation: ring-shift 6s ease infinite;
    }

    @keyframes ring-shift {
      0%, 100% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
    }
  </style>

  <!-- Biography -->
  <section id="about" class="py-[var(--space-section)] bg-bg-accent">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6 flex flex-col md:flex-row gap-12 items-start">
      <div class="shrink-0 mx-auto md:mx-0">
        <div class="avatar-ring rounded-full p-[3px]">
          <img
            src="/avatar.png"
            alt="Théo Hermann"
            width="180"
            height="180"
            class="rounded-full block"
          />
        </div>
        <div class="mt-4 text-center md:text-left">
          <p class="text-xl font-bold text-text-primary">{author.name}</p>
          <p class="text-sm text-text-muted">{author.role}</p>
          <p class="text-sm text-text-muted">{author.affiliation}</p>
        </div>
        <div class="flex gap-3 mt-4 justify-center md:justify-start">
          {author.social.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" class="text-text-muted hover:text-text-secondary transition-colors" title={s.label}>
              <SocialIcon type={s.icon as 'email' | 'github' | 'linkedin' | 'scholar'} />
            </a>
          ))}
        </div>
      </div>
      <div class="flex-1 max-w-prose">
        {author.bio.map((paragraph) => (
          <p class="text-text-secondary leading-relaxed mb-4" set:html={paragraph} />
        ))}
        <div class="mt-6">
          <Button href="/cv" variant="secondary">Full CV</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest News -->
  <section id="news" class="py-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h2 class="text-2xl font-bold text-text-primary mb-8">Latest</h2>
      <div class="max-w-xl">
        {newsItems.map((item) => (
          <NewsItem date={item.date} text={item.text} />
        ))}
      </div>
      <p class="mt-6">
        <a href="/now" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)]">
          Full timeline & what I'm doing now →
        </a>
      </p>
    </div>
  </section>

  <!-- Featured Work -->
  <section id="projects" class="py-[var(--space-section)] bg-bg-secondary">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h2 class="text-2xl font-bold text-text-primary mb-8">Featured Work</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredProjects.map((project, i) => (
          <ProjectCard {...project} number={i + 1} />
        ))}
      </div>
      <p class="text-center mt-8">
        <a href="/projects" class="text-sm text-[var(--color-link)] hover:text-[var(--color-link-hover)]">
          See all projects →
        </a>
      </p>
    </div>
  </section>

  <!-- Publications -->
  <section id="publications" class="py-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h2 class="text-2xl font-bold text-text-primary mb-8">Publications</h2>
      <div class="max-w-2xl">
        {publications.map((pub) => (
          <PublicationEntry
            title={pub.data.title}
            authors={pub.data.authors}
            venue={pub.data.publication}
            date={pub.data.date}
            doi={pub.data.doi}
            pdfUrl={pub.data.links?.pdf}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="contact-section relative py-[var(--space-section)] overflow-hidden">
    <div class="contact-bg absolute inset-0"></div>
    <div class="relative z-10 mx-auto max-w-[var(--max-w-content)] px-6 text-center">
      <h2 class="text-3xl font-bold text-text-primary mb-4">Let's Talk</h2>
      <p class="text-text-secondary mb-10 max-w-lg mx-auto text-lg">
        Looking for senior perception or robotics engineering roles. Open to companies working on autonomous vehicles, humanoid robots, and embodied AI.
      </p>
      <div class="flex justify-center gap-5 flex-wrap">
        <Button href="mailto:thermann@mit.edu">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          E-mail
        </Button>
        <Button href="https://www.linkedin.com/in/theohermann-epfl/" variant="secondary" external>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </Button>
      </div>
    </div>
  </section>

  <style>
    .contact-bg {
      background:
        radial-gradient(ellipse 80% 60% at 50% 100%, rgba(59, 130, 246, 0.08) 0%, transparent 70%),
        linear-gradient(180deg, var(--color-bg-accent) 0%, #0d1020 50%, var(--color-bg-accent) 100%);
    }

    :global([data-theme="light"]) .contact-bg {
      background:
        radial-gradient(ellipse 80% 60% at 50% 100%, rgba(59, 130, 246, 0.1) 0%, transparent 70%),
        linear-gradient(180deg, var(--color-bg-accent) 0%, #e0e7f5 50%, var(--color-bg-accent) 100%);
    }

    @media (prefers-color-scheme: light) {
      :global(:root:not([data-theme])) .contact-bg {
        background:
          radial-gradient(ellipse 80% 60% at 50% 100%, rgba(59, 130, 246, 0.1) 0%, transparent 70%),
          linear-gradient(180deg, var(--color-bg-accent) 0%, #e0e7f5 50%, var(--color-bg-accent) 100%);
      }
    }
  </style>
</PageLayout>
