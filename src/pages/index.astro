---
import PageLayout from '../layouts/PageLayout.astro';
import FeaturedStrip from '../components/FeaturedStrip.astro';
import Marginalia from '../components/composition/Marginalia.astro';
import SectionRule from '../components/composition/SectionRule.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../data/site';
import { author } from '../data/author';

const writingAll = await getCollection('writing');
const latestWriting = writingAll
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 1)[0];
---

<PageLayout description={siteConfig.description}>
  <section class="hero">
    <div class="grid-cartesian">
      <h1 class="wordmark-hero col-1-8" aria-label={author.name}>
        Théo<br />
        <em>Alessandro</em><br />
        Hermann
      </h1>
      <aside class="hero-aside col-10-12">
        <Marginalia voice="mono">
          Rio · 2026<br />
          Franco-Brazilian engineer
        </Marginalia>
      </aside>
      <p class="hero-positioning col-1-7">
        Researcher and builder. <span class="hero-positioning-em">MIT Senseable Rio.</span>
        Urban science, robotics, and what comes next.
      </p>
    </div>
  </section>

  <div class="page-wrap">
    <FeaturedStrip />

    {
      latestWriting && (
        <section class="writing-section">
          <SectionRule>Writing</SectionRule>
          <div class="grid-cartesian writing-grid">
            <a href={`/writing/${latestWriting.id}`} class="writing-card col-1-8">
              <span class="mono-caption">
                {latestWriting.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </span>
              <h3 class="writing-title">{latestWriting.data.title}</h3>
              <p class="writing-summary">{latestWriting.data.summary}</p>
            </a>
            <aside class="col-10-12 writing-meta">
              <Marginalia voice="mono">Notes & essays — irregular cadence</Marginalia>
            </aside>
          </div>
        </section>
      )
    }
  </div>
</PageLayout>

<style>
  .hero {
    padding-block: clamp(3rem, 9vw, 6rem) var(--s-16);
  }
  .hero .grid-cartesian {
    row-gap: var(--s-12);
  }

  /* Wordmark-hero — THE typographic moment (Phase 4.7 A1).
     Cartesian display face (Space Grotesk) at --text-hero scale; the
     <em> middle line is italic and lighter for tension. Aria label on
     the h1 preserves the spoken name. */
  .wordmark-hero {
    font-family: var(--font-cartesian);
    font-size: var(--text-hero);
    font-weight: 500;
    line-height: 0.88;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0;
  }
  .wordmark-hero em {
    font-style: italic;
    font-weight: 300;
    letter-spacing: -0.04em;
  }

  .hero-aside {
    align-self: end;
    padding-bottom: var(--s-2);
  }
  @media (max-width: 719px) {
    .hero-aside {
      margin-top: var(--s-6);
    }
  }

  .hero-positioning {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    line-height: 1.45;
    color: var(--color-ink-soft);
    margin: 0;
  }
  .hero-positioning-em {
    color: var(--color-ink);
    font-weight: 500;
  }

  .writing-section {
    margin-top: var(--space-section);
  }
  .writing-grid {
    padding-inline: 0;
    max-width: none;
  }

  .writing-card {
    display: block;
    text-decoration: none;
    padding: var(--s-4) 0;
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    color: var(--color-ink);
    transition: border-color 250ms ease;
  }
  .writing-card:hover {
    border-color: var(--color-rule-strong);
  }
  .writing-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-sm);
    font-weight: 600;
    margin-top: var(--s-2);
    letter-spacing: -0.015em;
  }
  .writing-card:hover .writing-title {
    color: var(--color-accent);
  }
  .writing-summary {
    color: var(--color-ink-muted);
    margin-top: var(--s-2);
    max-width: 62ch;
    font-size: var(--text-body-sm);
  }
  .writing-meta {
    align-self: center;
  }
</style>
