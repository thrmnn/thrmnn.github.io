---
import PageLayout from '../layouts/PageLayout.astro';
import MonoRow from '../components/typography/MonoRow.astro';
import SectionRule from '../components/composition/SectionRule.astro';

const updated = new Date(2026, 4, 1); // May 2026
const updatedLabel = updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });

const blocks = [
  {
    label: 'Research',
    body: 'Two papers in motion. The Amsterdam tree-shade study went to Nature Cities this week. The favela morphology paper — LiDAR, CFD airflow, solar exposure — is the next submission, targeting June.',
  },
  {
    label: 'Robotics',
    body: 'Building an open VLA benchmark on lerobot. Public release end of June. Reading recent world-model work in parallel.',
  },
  {
    label: 'Building',
    body: 'Two stealth apps with shipping deadlines in May and June. Not yet linked from this site. Separate from Azimuth — an AI infrastructure agency launching alongside, kept under its own brand.',
  },
  {
    label: 'Open to',
    body: 'Senior research and engineering conversations at frontier AI labs, and a small number of consulting engagements at the intersection of built environment and AI infrastructure.',
  },
];
---

<PageLayout title="Now" description="What Théo Alessandro Hermann is focused on this month.">
  <section class="now grid-cartesian">
    <div class="col-1-13 now-head">
      <MonoRow pieces={['Now', `Updated ${updatedLabel}`]} />
    </div>
    <h1 class="col-1-9 now-title">May 2026 · Rio</h1>
    <p class="col-3-9 now-lede">
      A monthly snapshot of what's open, what's shipping, and what's next.
    </p>

    <div class="col-1-13">
      <SectionRule align="start">Active</SectionRule>
    </div>

    {
      blocks.map((b) => (
        <>
          <div class="col-1-3 block-label">
            <span class="mono-caption">{b.label}</span>
          </div>
          <p class="col-3-10 block-body">{b.body}</p>
        </>
      ))
    }

    <div class="col-1-13">
      <SectionRule />
    </div>

    <p class="col-1-9 now-attribution mono-caption">
      <a href="https://sive.rs/nowff" rel="noopener">/now page</a>, after Derek Sivers · Monthly refresh
    </p>
  </section>
</PageLayout>

<style>
  .now {
    padding-block: clamp(2.5rem, 6vw, 4rem) var(--space-section);
    row-gap: var(--s-6);
  }
  .now-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .now-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-lg);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
    margin: 0;
  }
  .now-lede {
    font-family: var(--font-body);
    color: var(--color-ink-soft);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    margin: 0;
    margin-top: var(--s-4);
  }

  .block-label {
    padding-top: var(--s-2);
  }
  .block-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-ink);
    margin: 0;
    max-width: 60ch;
  }

  @media (max-width: 719px) {
    .block-label {
      padding-top: 0;
      margin-top: var(--s-4);
    }
  }

  .now-attribution {
    margin-top: var(--s-4);
    color: var(--color-ink-muted);
  }
  .now-attribution a {
    color: inherit;
  }
</style>
