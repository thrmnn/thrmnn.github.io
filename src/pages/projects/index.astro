---
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ui/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => !data.draft);
const featured = projects
  .filter((p) => p.data.featuredOrder !== undefined)
  .sort((a, b) => a.data.featuredOrder! - b.data.featuredOrder!);
const rest = projects
  .filter((p) => p.data.featuredOrder === undefined)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const ordered = [...featured, ...rest];
---

<PageLayout title="Projects" description="Research and engineering projects spanning perception, autonomous navigation, 3D urban intelligence, and robot learning.">
  <section class="py-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h1 class="text-3xl font-bold text-text-primary mb-2" data-reveal>Projects</h1>
      <p class="text-text-secondary mb-10 max-w-2xl" data-reveal style="--reveal-d: 1;">
        Perception, autonomy, and 3D reconstruction — from production systems deployed on physical hardware to research prototypes across maritime, aerial, and urban domains.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {ordered.map((project, i) => (
          <ProjectCard
            title={project.data.title}
            label={project.data.label}
            metric={project.data.metric}
            tags={project.data.tags}
            detail={project.data.summary}
            href={`/projects/${project.id}/`}
            gradient={project.data.gradient}
            image={project.data.image}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
