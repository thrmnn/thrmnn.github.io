---
import PageLayout from '../../layouts/PageLayout.astro';
import PublicationEntry from '../../components/ui/PublicationEntry.astro';
import { getCollection } from 'astro:content';

const publications = (await getCollection('publications')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<PageLayout title="Research" description="Publications, conference papers, and technical writing.">
  <section class="py-[var(--space-section)]">
    <div class="mx-auto max-w-[var(--max-w-content)] px-6">
      <h1 class="text-3xl font-bold text-text-primary mb-10">Research</h1>

      <h2 class="text-xl font-semibold text-text-primary mb-6">Publications</h2>
      <div class="max-w-2xl">
        {publications.map((pub) => (
          <PublicationEntry
            id={pub.id}
            href={`/research/${pub.id}/`}
            title={pub.data.title}
            authors={pub.data.authors}
            venue={pub.data.publication}
            date={pub.data.date}
            doi={pub.data.doi}
            pdfUrl={pub.data.links?.pdf}
          />
        ))}
      </div>
    </div>
  </section>
</PageLayout>
