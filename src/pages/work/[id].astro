---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Breadcrumb from '../../components/nav/Breadcrumb.astro';
import StatusPill from '../../components/primitives/StatusPill.astro';
import PaperGrainOverlay from '../../components/primitives/PaperGrainOverlay.astro';
import VerticalLabel from '../../components/composition/VerticalLabel.astro';
import SectionNumber from '../../components/composition/SectionNumber.astro';
import SectionRule from '../../components/composition/SectionRule.astro';
import ExternalLink from '../../components/primitives/ExternalLink.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });

const yyyyMm = `${d.date.getFullYear()}-${String(d.date.getMonth() + 1).padStart(2, '0')}`;

const updatedLabel = d.updated
  ? d.updated.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const links = [
  d.links.paper && { label: 'Paper', href: d.links.paper },
  d.links.preprint && { label: 'Preprint', href: d.links.preprint },
  d.links.repo && { label: 'Code', href: d.links.repo },
  d.links.app && { label: 'App', href: d.links.app },
  d.links.site && { label: 'Site', href: d.links.site },
].filter((l): l is { label: string; href: string } => Boolean(l));

const all = await getCollection('projects');
const related = all
  .filter((p) => p.id !== project.id)
  .map((p) => ({
    p,
    overlap: p.data.tags.filter((t) => d.tags.includes(t)).length,
  }))
  .filter((r) => r.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap)
  .slice(0, 2)
  .map((r) => r.p);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  headline: d.title,
  description: d.summary,
  datePublished: d.date.toISOString(),
  dateModified: (d.updated ?? d.date).toISOString(),
  keywords: d.tags.join(', '),
};
---

<PageLayout
  title={d.title}
  description={d.summary}
  ogType="article"
  register={d.register}
  articleJsonLd={articleJsonLd}
>
  <article class="project grid-cartesian">
    <aside class="col-1-2 project-side" aria-hidden="true">
      <VerticalLabel>Project · {d.date.getFullYear()}</VerticalLabel>
    </aside>

    <header class="col-2-13 project-header">
      <Breadcrumb />
      {
        d.status && (
          <p class="status-line">
            <StatusPill tone={d.register === 'tropical' ? 'terra' : 'graphite'}>
              {d.status}
            </StatusPill>
          </p>
        )
      }
      <h1 class="project-title">{d.title}</h1>
      {d.subtitle && <p class="project-subtitle">{d.subtitle}</p>}
      {updatedLabel && <p class="updated-line mono-caption">Updated {updatedLabel}</p>}
    </header>

    <div class="col-2-13 project-hero-wrap">
      {
        d.heroImage ? (
          <figure class="project-hero" data-kind={d.heroKind}>
            <img src={d.heroImage} alt={d.heroAlt ?? d.title} />
            {d.heroKind === 'photo' && <PaperGrainOverlay />}
          </figure>
        ) : (
          <div class="project-hero hero-placeholder" aria-hidden="true">
            <span class="placeholder-mark">{d.title}</span>
          </div>
        )
      }
    </div>

    <!-- 01 Context -->
    <div class="col-2-5 section-label">
      <SectionNumber>01</SectionNumber>
      <h2 class="section-heading">Context</h2>
    </div>
    <div class="col-5-12 section-body section-body--lede">
      <p>{d.summary}</p>
    </div>

    <div class="col-2-13"><SectionRule /></div>

    <!-- 02 Method -->
    <div class="col-2-5 section-label">
      <SectionNumber>02</SectionNumber>
      <h2 class="section-heading">Method</h2>
    </div>
    <div class="col-5-12 section-body prose">
      <Content />
    </div>

    <div class="col-2-13"><SectionRule /></div>

    <!-- 03 Findings & links -->
    <div class="col-2-5 section-label">
      <SectionNumber>03</SectionNumber>
      <h2 class="section-heading">Findings & links</h2>
    </div>
    <div class="col-5-12 section-body">
      {
        links.length > 0 ? (
          <ul class="links-list">
            {links.map((l) => (
              <li>
                <ExternalLink href={l.href}>{l.label}</ExternalLink>
              </li>
            ))}
          </ul>
        ) : (
          <p class="empty">Findings not yet linked.</p>
        )
      }
      {
        d.tags.length > 0 && (
          <p class="tags mono-caption">
            {d.tags.map((tag, i) => (
              <>
                {i > 0 && (
                  <span aria-hidden="true" class="tag-sep">
                    /
                  </span>
                )}
                {tag}
              </>
            ))}
          </p>
        )
      }
    </div>

    <div class="col-2-13"><SectionRule /></div>

    <!-- 04 Credit -->
    <div class="col-2-5 section-label">
      <SectionNumber>04</SectionNumber>
      <h2 class="section-heading">Credit</h2>
    </div>
    <div class="col-5-12 section-body">
      <dl class="credit-list">
        <div class="credit-row">
          <dt class="mono-caption">Date</dt>
          <dd>{formatDate(d.date)}</dd>
        </div>
        {
          d.collaborators.length > 0 && (
            <div class="credit-row">
              <dt class="mono-caption">With</dt>
              <dd>{d.collaborators.join(', ')}</dd>
            </div>
          )
        }
        {
          d.updated && (
            <div class="credit-row">
              <dt class="mono-caption">Updated</dt>
              <dd>{formatDate(d.updated)}</dd>
            </div>
          )
        }
      </dl>
    </div>

    {
      related.length > 0 && (
        <section class="col-2-13 related">
          <SectionRule align="start">Related work</SectionRule>
          <div class="related-grid">
            {related.map((r) => (
              <ProjectCard project={r} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</PageLayout>

<style>
  .project {
    padding-block: clamp(2rem, 5vw, 3.5rem) var(--space-section);
    row-gap: var(--s-8);
  }

  .project-side {
    position: sticky;
    top: var(--s-20);
    align-self: start;
    height: 0;
  }
  @media (max-width: 719px) {
    .project-side {
      display: none;
    }
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    margin-bottom: var(--s-6);
  }
  .status-line {
    margin: var(--s-2) 0 0;
  }
  .project-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-lg);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
    max-width: 22ch;
    margin: var(--s-2) 0 0;
  }
  [data-register='tropical'] .project-title {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings:
      'opsz' 144,
      'SOFT' 60;
    letter-spacing: -0.015em;
  }
  .project-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-ink-soft);
    max-width: 50ch;
    line-height: 1.5;
    margin: 0;
  }
  .updated-line {
    color: var(--color-ink-muted);
    margin: 0;
  }

  .project-hero-wrap {
    margin-block: var(--s-6);
  }
  .project-hero {
    border: 1px solid var(--color-rule);
    overflow: hidden;
    position: relative;
    margin: 0;
  }
  .project-hero img {
    width: 100%;
    height: auto;
    display: block;
  }
  .hero-placeholder {
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: flex-end;
    padding: var(--s-8);
    background: linear-gradient(135deg, var(--color-paper-deep) 0%, var(--color-paper) 100%);
    position: relative;
  }
  .hero-placeholder::before {
    content: '';
    position: absolute;
    inset: var(--s-6);
    border: 1px solid var(--color-rule);
  }
  [data-register='tropical'] .hero-placeholder {
    background: linear-gradient(135deg, var(--color-sand) 0%, var(--color-paper) 80%);
  }
  .placeholder-mark {
    font-family: var(--font-wordmark);
    font-variation-settings:
      'opsz' 144,
      'SOFT' 60;
    font-size: var(--text-display-md);
    color: var(--color-ink-soft);
    max-width: 70%;
    line-height: 1.05;
    position: relative;
    z-index: 1;
  }

  /* Numbered sections — label sits in col 2-5, content in col 5-12.
     Section heading is Cartesian (or Fraunces in Tropical) at display-sm. */
  .section-label {
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
    align-items: flex-start;
  }
  .section-heading {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-sm);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.15;
    margin: 0;
  }
  [data-register='tropical'] .section-heading {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings:
      'opsz' 36,
      'SOFT' 50;
  }
  .section-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-ink-soft);
  }
  .section-body--lede {
    font-size: var(--text-body-lg);
    color: var(--color-ink);
  }
  .section-body p {
    margin: 0 0 1em;
  }
  .section-body p:last-child {
    margin-bottom: 0;
  }

  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .links-list a {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink);
  }
  .empty {
    color: var(--color-ink-muted);
    font-style: italic;
    margin: 0;
  }
  .tags {
    margin-top: var(--s-6);
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    align-items: baseline;
  }
  .tag-sep {
    color: var(--color-ink-muted);
    opacity: 0.55;
    margin: 0 var(--s-1);
  }

  .credit-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .credit-row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: var(--s-4);
    align-items: baseline;
  }
  .credit-row dt {
    margin: 0;
  }
  .credit-row dd {
    margin: 0;
    color: var(--color-ink-soft);
  }
  @media (max-width: 520px) {
    .credit-row {
      grid-template-columns: 1fr;
      gap: var(--s-1);
    }
  }

  .related {
    margin-top: var(--space-section);
  }
  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }
  @media (min-width: 720px) {
    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
