---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Breadcrumb from '../../components/nav/Breadcrumb.astro';
import StatusPill from '../../components/primitives/StatusPill.astro';
import VerticalLabel from '../../components/composition/VerticalLabel.astro';
import SectionNumber from '../../components/composition/SectionNumber.astro';
import SectionRule from '../../components/composition/SectionRule.astro';
import Figure from '../../components/composition/Figure.astro';
import ExternalLink from '../../components/primitives/ExternalLink.astro';
import TagPill from '../../components/primitives/TagPill.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
const d = project.data;

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });

const updatedLabel = d.updated
  ? d.updated.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
  : null;

const links = [
  d.links.paper && { label: 'Paper', href: d.links.paper },
  d.links.preprint && { label: 'Preprint', href: d.links.preprint },
  d.links.repo && { label: 'Code', href: d.links.repo },
  d.links.app && { label: 'App', href: d.links.app },
  d.links.site && { label: 'Site', href: d.links.site },
].filter((l): l is { label: string; href: string } => Boolean(l));

const all = await getCollection('projects');
const related = all
  .filter((p) => p.id !== project.id)
  .map((p) => ({
    p,
    overlap: p.data.tags.filter((t) => d.tags.includes(t)).length,
  }))
  .filter((r) => r.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap)
  .slice(0, 2)
  .map((r) => r.p);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  headline: d.title,
  description: d.summary,
  datePublished: d.date.toISOString(),
  dateModified: (d.updated ?? d.date).toISOString(),
  keywords: d.tags.join(', '),
};
---

<PageLayout
  title={d.title}
  description={d.summary}
  ogType="article"
  register={d.register}
  articleJsonLd={articleJsonLd}
>
  <article class="project">
    <section class="project-intro grid-cartesian">
      <header class="col-1-12 project-header">
        <Breadcrumb />
        <div class="project-title-grid">
          <div class="project-title-stack">
            <h1 class="project-title">{d.title}</h1>
            {d.subtitle && <p class="project-subtitle">{d.subtitle}</p>}
          </div>
          {
            d.status && (
              <div class="project-status-cell">
                <StatusPill tone={d.register === 'tropical' ? 'terra' : 'graphite'}>
                  {d.status}
                </StatusPill>
              </div>
            )
          }
        </div>
        {updatedLabel && <p class="updated-line mono-caption">Updated {updatedLabel}</p>}
      </header>

      <div class="col-1-12 project-hero-wrap">
        <Figure
          caption={d.title}
          meta={d.tags.slice(0, 4)}
          ratio="3/2"
          src={d.heroImage}
          alt={d.heroAlt ?? d.title}
          pending={!d.heroImage}
        />
      </div>
    </section>

    <section class="project-section grid-cartesian" id="context">
      <div class="col-1-1 project-section-label">
        <VerticalLabel>CONTEXT</VerticalLabel>
      </div>
      <div class="col-2-2 project-section-number">
        <SectionNumber>01</SectionNumber>
      </div>
      <div class="col-3-9 project-section-body project-section-body--lede">
        <p>{d.summary}</p>
      </div>
    </section>

    <section class="project-section grid-cartesian" id="method">
      <div class="col-1-1 project-section-label">
        <VerticalLabel>METHOD</VerticalLabel>
      </div>
      <div class="col-2-2 project-section-number">
        <SectionNumber>02</SectionNumber>
      </div>
      <div class="col-3-9 project-section-body prose">
        <Content />
      </div>
    </section>

    <section class="project-section grid-cartesian" id="findings">
      <div class="col-1-1 project-section-label">
        <VerticalLabel>FINDINGS</VerticalLabel>
      </div>
      <div class="col-2-2 project-section-number">
        <SectionNumber>03</SectionNumber>
      </div>
      <div class="col-3-9 project-section-body">
        {
          links.length > 0 ? (
            <ul class="links-list">
              {links.map((l) => (
                <li>
                  <ExternalLink href={l.href}>{l.label}</ExternalLink>
                </li>
              ))}
            </ul>
          ) : (
            <p class="credit-pending mono-caption mono-caption--xs">
              ⧉&nbsp;&nbsp;Findings surfaced on publication
            </p>
          )
        }
      </div>
    </section>

    <p class="end-of-doc mono-caption" aria-hidden="true">
      END · 04 SECTIONS · {formatDate(d.updated ?? d.date).toUpperCase()}
    </p>

    <section class="project-section grid-cartesian" id="credit">
      <div class="col-1-1 project-section-label">
        <VerticalLabel>CREDIT</VerticalLabel>
      </div>
      <div class="col-2-2 project-section-number">
        <SectionNumber>04</SectionNumber>
      </div>
      <div class="col-3-9 project-section-body">
        <div class="credit-block">
          <h3 class="mono-caption credit-heading">WITH</h3>
          {
            d.collaborators.length > 0 ? (
              <ul class="credit-list-inline">
                {d.collaborators.map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            ) : (
              <p class="credit-pending mono-caption mono-caption--xs">
                ⧉&nbsp;&nbsp;Collaborators surfaced on publication
              </p>
            )
          }
        </div>

        <div class="credit-block">
          <h3 class="mono-caption credit-heading">LINKS</h3>
          {
            links.length > 0 ? (
              <ul class="credit-list-inline">
                {links.map((l) => (
                  <li>
                    <ExternalLink href={l.href}>{l.label}</ExternalLink>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="credit-pending mono-caption mono-caption--xs">
                ⧉&nbsp;&nbsp;Links surfaced on release
              </p>
            )
          }
        </div>

        {
          d.tags.length > 0 && (
            <div class="credit-block">
              <h3 class="mono-caption credit-heading">TAGS</h3>
              <div class="tag-row">
                {d.tags.map((t) => (
                  <TagPill>{t}</TagPill>
                ))}
              </div>
            </div>
          )
        }

        <div class="credit-block">
          <h3 class="mono-caption credit-heading">DATE</h3>
          <p class="credit-value">{formatDate(d.date)}</p>
        </div>

        {
          d.updated && (
            <div class="credit-block">
              <h3 class="mono-caption credit-heading">UPDATED</h3>
              <p class="credit-value">{formatDate(d.updated)}</p>
            </div>
          )
        }
      </div>
    </section>

    {
      related.length > 0 && (
        <section class="project-related grid-cartesian">
          <div class="col-1-12">
            <SectionRule align="start">Related work</SectionRule>
          </div>
          <div class="col-1-12 related-grid">
            {related.map((r) => (
              <ProjectCard project={r} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</PageLayout>

<style>
  .project {
    padding-block: clamp(2rem, 5vw, 3.5rem) var(--space-section);
    display: flex;
    flex-direction: column;
    gap: var(--s-16);
  }
  .project-intro {
    row-gap: var(--s-8);
  }
  .project-section {
    row-gap: var(--s-4);
    align-items: start;
  }
  .project-related {
    margin-top: var(--s-8);
  }

  .project-header {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .project-title-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    column-gap: var(--s-6);
    row-gap: var(--s-3);
    align-items: start;
  }
  .project-title-stack {
    grid-column: 1 / 10;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .project-status-cell {
    grid-column: 10 / 13;
    display: flex;
    justify-content: flex-end;
    padding-top: var(--s-2);
  }
  @media (max-width: 720px) {
    .project-title-grid {
      grid-template-columns: 1fr;
    }
    .project-title-stack,
    .project-status-cell {
      grid-column: 1;
    }
    .project-status-cell {
      justify-content: flex-start;
      padding-top: 0;
    }
  }
  .project-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-xl);
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.025em;
    max-width: 12ch;
    text-wrap: balance;
    margin: var(--s-2) 0 0;
  }
  [data-register='tropical'] .project-title {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings:
      'opsz' 144,
      'SOFT' 60;
    letter-spacing: -0.015em;
  }
  .project-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-body-lg);
    color: var(--color-ink-soft);
    max-width: 50ch;
    line-height: 1.5;
    margin: 0;
  }
  .updated-line {
    color: var(--color-ink-muted);
    margin: 0;
  }

  /* Section anatomy (Phase 4.7 D5):
       col-1-1: rotated VerticalLabel for the section name
       col-2-2: large terra SectionNumber as typographic anchor
       col-3-9: body content
     VerticalLabel and SectionNumber both position: sticky so they
     stay alongside the body as it scrolls. */
  .project-section-label,
  .project-section-number {
    align-self: start;
  }
  .project-section-label .vertical-label {
    position: sticky;
    top: var(--s-20);
  }
  .project-section-body {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--color-ink-soft);
  }
  .project-section-body--lede {
    font-size: var(--text-body-lg);
    color: var(--color-ink);
  }
  .project-section-body p {
    margin: 0 0 1em;
  }
  .project-section-body p:last-child {
    margin-bottom: 0;
  }
  @media (max-width: 719px) {
    .project-section-label .vertical-label,
    .project-section-number :global(.section-number) {
      position: static;
    }
  }

  .links-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-3);
  }
  .links-list a {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink);
  }

  /* Credit section blocks (D6) — each block is a heading + content
     (or pending state). The pending state IS the design surface, not
     a fallback — Anna's principle. */
  .credit-block {
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    margin-bottom: var(--s-8);
  }
  .credit-block:last-child {
    margin-bottom: 0;
  }
  .credit-heading {
    margin: 0 0 var(--s-1);
    font-weight: 400;
  }
  .credit-list-inline {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-2);
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink-soft);
  }
  .credit-value {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-ink-soft);
    margin: 0;
  }
  .credit-pending {
    color: var(--color-ink-muted);
    margin: 0;
    padding: var(--s-2) 0;
  }
  .credit-pending::before {
    /* ⧉ glyph is inline-rendered with non-breaking spaces; no extra ::before. */
  }

  /* End-of-document signal (Phase 4.7 D8). Sits between section 03
     (Findings) and section 04 (Credit) — Credit is metadata, the body
     ends above it. Editorial polish; reads as document, not webpage. */
  .end-of-doc {
    text-align: center;
    padding-block: var(--s-12);
    color: var(--color-ink-muted);
    letter-spacing: 0.2em;
    margin: 0;
  }
  .end-of-doc::before {
    content: '— —  ';
  }
  .end-of-doc::after {
    content: '  — —';
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-6);
  }
  @media (min-width: 720px) {
    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
