---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/nav/Breadcrumb.astro';
import StatusPill from '../../components/primitives/StatusPill.astro';
import SectionRule from '../../components/composition/SectionRule.astro';

const all = await getCollection('writing');
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const languageLabel: Record<string, string> = {
  en: 'EN',
  fr: 'FR',
  pt: 'PT',
};
---

<PageLayout title="Writing" description="Essays and field notes by Théo Alessandro Hermann.">
  <section class="writing grid-cartesian">
    <div class="col-1-13 writing-head">
      <Breadcrumb />
    </div>
    <h1 class="col-1-9 writing-title">Essays and field notes</h1>
    <p class="col-3-9 writing-lede">
      Long-form on urban science, robotics, and the work between them. Pieces appear in English,
      French, or Portuguese — tagged accordingly.
    </p>

    <div class="col-1-13">
      <SectionRule align="start">All writing · by date</SectionRule>
    </div>

    {
      sorted.length === 0 ? (
        <div class="col-1-9 empty">
          <p>First essays drop later this year. The page exists for when they do.</p>
          <p class="empty-meta">
            <a href="/rss.xml">RSS feed</a> · <a href="/now">What I'm writing now</a>
          </p>
        </div>
      ) : (
        <ol class="col-1-13 writing-list">
          {sorted.map((entry) => (
            <li class="writing-entry" data-register={entry.data.register}>
              <a href={`/writing/${entry.id}`} class="entry-link">
                <span class="entry-date mono-caption">
                  {entry.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                  <StatusPill tone={entry.data.register === 'tropical' ? 'oxblood' : 'graphite'}>
                    {languageLabel[entry.data.language]}
                  </StatusPill>
                </span>
                <h2 class="entry-title">{entry.data.title}</h2>
                <p class="entry-summary">{entry.data.summary}</p>
              </a>
            </li>
          ))}
        </ol>
      )
    }
  </section>
</PageLayout>

<style>
  .writing {
    padding-block: clamp(2.5rem, 6vw, 4rem) var(--space-section);
    row-gap: var(--s-6);
  }
  .writing-head {
    display: flex;
    flex-direction: column;
    gap: var(--s-4);
  }
  .writing-title {
    font-family: var(--font-cartesian);
    font-size: var(--text-display-lg);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: -0.025em;
    max-width: 20ch;
    margin: 0;
  }
  .writing-lede {
    font-family: var(--font-body);
    color: var(--color-ink-soft);
    font-size: var(--text-body-lg);
    line-height: 1.55;
    margin: 0;
    margin-top: var(--s-4);
  }

  .empty {
    padding: var(--s-6) 0;
    color: var(--color-ink-soft);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    font-family: var(--font-body);
    font-size: var(--text-body);
  }
  .empty p {
    margin: 0 0 var(--s-3);
  }
  .empty-meta {
    font-size: var(--text-body-sm);
    color: var(--color-ink-muted);
    margin: 0;
  }

  .writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }
  .writing-entry {
    border-bottom: 1px solid var(--color-rule);
  }
  .entry-link {
    display: block;
    padding: var(--s-6) 0;
    color: var(--color-ink);
    text-decoration: none;
    transition: padding-left 250ms ease;
  }
  .entry-link:hover {
    padding-left: var(--s-2);
  }
  .entry-date {
    display: inline-flex;
    gap: var(--s-3);
    align-items: center;
  }
  .entry-title {
    margin-top: var(--s-2);
    font-family: var(--font-cartesian);
    font-size: var(--text-display-sm);
    line-height: 1.25;
    letter-spacing: -0.015em;
    font-weight: 500;
  }
  [data-register='tropical'] .entry-title {
    font-family: var(--font-tropical);
    font-weight: 450;
    font-variation-settings:
      'opsz' 36,
      'SOFT' 50;
  }
  .entry-link:hover .entry-title {
    color: var(--color-accent);
  }
  .entry-summary {
    margin-top: var(--s-2);
    color: var(--color-ink-muted);
    max-width: 62ch;
    font-size: var(--text-body-sm);
  }
</style>
