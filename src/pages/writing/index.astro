---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumb from '../../components/nav/Breadcrumb.astro';

const all = await getCollection('writing');
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const languageLabel: Record<string, string> = {
  en: 'EN',
  fr: 'FR',
  pt: 'PT',
};
---

<PageLayout title="Writing" description="Essays and field notes by Théo Alessandro Hermann.">
  <section class="page-wrap writing">
    <Breadcrumb />
    <header class="writing-head">
      <span class="mono-caption">Writing</span>
      <h1 class="writing-title">Essays and field notes</h1>
      <p class="writing-lede">
        Long-form on urban science, robotics, and the work between them. Pieces appear in English,
        French, or Portuguese — tagged accordingly.
      </p>
    </header>

    {
      sorted.length === 0 ? (
        <div class="empty">
          <p>First essays drop later this year. The page exists for when they do.</p>
          <p class="empty-meta">
            <a href="/rss.xml">RSS feed</a> · <a href="/now">What I'm writing now</a>
          </p>
        </div>
      ) : (
        <ol class="writing-list">
          {sorted.map((entry) => (
            <li class="writing-entry" data-register={entry.data.register}>
              <a href={`/writing/${entry.id}`} class="entry-link">
                <span class="mono-caption entry-date">
                  {entry.data.date.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                  <span class="entry-lang">{languageLabel[entry.data.language]}</span>
                </span>
                <h2 class="entry-title">{entry.data.title}</h2>
                <p class="entry-summary">{entry.data.summary}</p>
              </a>
            </li>
          ))}
        </ol>
      )
    }
  </section>
</PageLayout>

<style>
  .writing {
    padding-block: clamp(2.5rem, 6vw, 4rem) var(--space-section);
  }
  .writing-head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 60ch;
    margin-bottom: 3rem;
  }
  .writing-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.1;
  }
  .writing-lede {
    font-family: var(--font-body);
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .empty {
    padding: 2rem 0;
    color: var(--color-ink-soft);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
  }
  .empty-meta {
    margin-top: 0.75rem;
    font-size: 0.92rem;
    color: var(--color-ink-muted);
  }

  .writing-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--color-rule);
  }
  .writing-entry {
    border-bottom: 1px solid var(--color-rule);
  }
  .entry-link {
    display: block;
    padding: 1.5rem 0;
    color: var(--color-ink);
    text-decoration: none;
    transition: padding-left 250ms ease;
  }
  .entry-link:hover {
    padding-left: 0.5rem;
  }
  .entry-date {
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
  }
  .entry-lang {
    padding: 0.05rem 0.4rem;
    border: 1px solid var(--color-rule-strong);
    border-radius: 2px;
    font-size: 0.65rem;
  }
  .entry-title {
    margin-top: 0.5rem;
    font-size: 1.35rem;
    line-height: 1.25;
    letter-spacing: -0.015em;
  }
  .entry-link:hover .entry-title {
    color: var(--color-accent);
  }
  .entry-summary {
    margin-top: 0.4rem;
    color: var(--color-ink-muted);
    max-width: 62ch;
    font-size: 0.98rem;
  }
</style>
